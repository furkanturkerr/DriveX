@model List<Rentaly.DtoLayer.BrandDtos.ResultBrandDto>

@{
    ViewData["Title"] = "Marka Yönetimi";
    Layout = "~/Views/Admin/Index.cshtml";
}

<div style="padding:20px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid #21262d">
        <div style="display:flex;align-items:center;gap:10px">
            <span style="width:7px;height:7px;background:#22c55e;border-radius:50%;display:inline-block"></span>
            <span style="font-size:14px;font-weight:500;color:#f0f6fc">Marka Yönetimi</span>
            <span style="font-size:10px;background:#0d2818;color:#22c55e;border:1px solid #22c55e33;padding:2px 9px;border-radius:20px">@(Model?.Count ?? 0) kayıt</span>
        </div>
        <a asp-action="CreateBrand" style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:#22c55e;color:#fff;border-radius:8px;font-size:12px;font-weight:500;text-decoration:none">
            <svg width="13" height="13" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 16 16"><path d="M8 3v10M3 8h10"/></svg>
            Marka Ekle
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div style="text-align:center;padding:52px;background:#161b22;border:1px dashed #30363d;border-radius:12px;color:#8b949e;font-size:13px">Henüz marka eklenmemiş</div>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px">
            @foreach (var item in Model)
            {
                <div style="background:#161b22;border:1px solid #21262d;border-radius:10px;padding:14px;display:flex;align-items:center;gap:10px">
                    <div style="width:40px;height:40px;background:#0d1117;border-radius:8px;overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="" style="width:100%;height:100%;object-fit:contain;padding:4px"/>
                        }
                        else
                        {
                            <span style="font-size:10px;font-weight:600;color:#6e7681">@(item.BrandName?.Substring(0,Math.Min(2,item.BrandName.Length)).ToUpper())</span>
                        }
                    </div>
                    <div style="flex:1;min-width:0">
                        <div style="font-size:12px;font-weight:500;color:#f0f6fc;overflow:hidden;white-space:nowrap;text-overflow:ellipsis">@item.BrandName</div>
                    </div>
                    <div style="display:flex;flex-direction:column;gap:4px">
                        <a asp-action="UpdateBrand" asp-route-id="@item.BrandId" style="font-size:10px;color:#22c55e;text-decoration:none">Düzenle</a>
                        <form asp-action="DeleteBrand" asp-route-id="@item.BrandId" method="post" onsubmit="return confirm('Emin misiniz?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="font-size:10px;color:#ef4444;background:none;border:none;cursor:pointer;padding:0">Sil</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>