@model List<Rentaly.DtoLayer.ContactDtos.ResultContactDto>

@{
    ViewData["Title"] = "İletişim Yönetimi";
    Layout = "~/Views/Admin/Index.cshtml";
    var contact = Model?.FirstOrDefault();
    bool hasRecord = contact != null;
}

<div style="padding:20px">

    <div style="display:flex;align-items:center;justify-content:space-between;
                margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid #21262d">
        <div style="display:flex;align-items:center;gap:10px">
            <span style="width:7px;height:7px;background:#22c55e;border-radius:50%;
                         display:inline-block"></span>
            <span style="font-size:14px;font-weight:500;color:#f0f6fc">İletişim Yönetimi</span>
            <span style="font-size:10px;background:#0d2818;color:#22c55e;
                         border:1px solid #22c55e33;padding:2px 9px;border-radius:20px">
                @(hasRecord ? "1 kayıt" : "0 kayıt")
            </span>
        </div>
        @if (!hasRecord)
        {
            <a asp-action="CreateContact"
               style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;
                      background:#22c55e;color:#fff;border-radius:8px;font-size:12px;
                      font-weight:500;text-decoration:none">
                <svg width="13" height="13" fill="none" stroke="#fff"
                     stroke-width="2" viewBox="0 0 16 16">
                    <path d="M8 3v10M3 8h10"/>
                </svg>
                İçerik Ekle
            </a>
        }
    </div>

    @if (!hasRecord)
    {
        <div style="text-align:center;padding:52px 20px;background:#161b22;
                    border:1px dashed #30363d;border-radius:12px">
            <svg width="40" height="40" fill="none" stroke="#30363d" stroke-width="1.5"
                 viewBox="0 0 16 16" style="margin:0 auto 14px;display:block">
                <path d="M2 3a1 1 0 0 1 1-1h2l1 3-1.5 1a9 9 0 0 0 4.5 4.5L11 9l3 1v2a1 1 0 0 1-1 1A13 13 0 0 1 2 3z"/>
            </svg>
            <div style="font-size:13px;color:#8b949e;margin-bottom:6px">
                Henüz içerik eklenmemiş
            </div>
            <div style="font-size:11px;color:#6e7681">
                Yukarıdaki "İçerik Ekle" butonuna tıklayın
            </div>
        </div>
    }
    else
    {
        <div style="background:#0c1f3d;border:1px solid #3b82f633;border-radius:8px;
                    padding:10px 14px;font-size:11px;color:#60a5fa;
                    display:flex;align-items:center;gap:8px;margin-bottom:14px">
            <svg width="14" height="14" fill="none" stroke="#60a5fa"
                 stroke-width="1.5" viewBox="0 0 16 16">
                <circle cx="8" cy="8" r="6"/><path d="M8 7v5M8 5v.5"/>
            </svg>
            Bu bölümde yalnızca 1 kayıt olabilir. Mevcut kaydı düzenleyebilirsiniz.
        </div>

        @* ÖNİZLEME *@
        <div style="background:#161b22;border:1px solid #21262d;
                    border-radius:12px;overflow:hidden;margin-bottom:14px">
            <div style="padding:9px 16px;border-bottom:1px solid #21262d;
                        display:flex;align-items:center;gap:6px;background:#0d1117">
                <span style="width:6px;height:6px;background:#22c55e;
                             border-radius:50%;display:inline-block"></span>
                <span style="font-size:10px;color:#6e7681;text-transform:uppercase;
                             letter-spacing:.6px;font-weight:500">Önizleme</span>
            </div>

            <div style="background:#22c55e;padding:28px 5%;
                        display:flex;align-items:center;gap:0">
                <div style="flex:1;padding-right:40px">
                    <div style="font-size:11px;font-weight:600;color:rgba(255,255,255,.85);
                                margin-bottom:10px">
                        @contact.SubTitle
                    </div>
                    <div style="font-size:22px;font-weight:700;color:#fff;line-height:1.3">
                        @contact.Title
                    </div>
                </div>
                <div style="flex:0 0 auto;text-align:center">
                    <div style="margin-bottom:6px">
                        <svg width="28" height="28" fill="#fff" viewBox="0 0 16 16">
                            <path d="M2 3a1 1 0 0 1 1-1h2l1 3-1.5 1a9 9 0 0 0 4.5 4.5L11 9l3 1v2a1 1 0 0 1-1 1A13 13 0 0 1 2 3z"/>
                        </svg>
                    </div>
                    <div style="font-size:9px;font-weight:600;color:rgba(255,255,255,.8);
                                letter-spacing:1.5px;margin-bottom:4px">
                        CALL US NOW
                    </div>
                    <div style="font-size:22px;font-weight:700;color:#fff;
                                letter-spacing:.5px;margin-bottom:12px">
                        @contact.Number
                    </div>
                    <div style="display:inline-block;padding:7px 20px;
                                background:#16a34a;color:#fff;border-radius:6px;
                                font-size:11px;font-weight:600">
                        İletişime Geç
                    </div>
                </div>
            </div>
        </div>

        @* DETAY KART *@
        <div style="background:#161b22;border:1px solid #21262d;border-radius:12px;overflow:hidden">

            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;
                        border-bottom:1px solid #21262d">
                <div style="padding:16px 20px;border-right:1px solid #21262d">
                    <div style="font-size:10px;color:#6e7681;font-weight:500;
                                text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">
                        Alt Başlık
                    </div>
                    <div style="font-size:12px;color:#f0f6fc;font-weight:500">
                        @contact.SubTitle
                    </div>
                </div>
                <div style="padding:16px 20px;border-right:1px solid #21262d">
                    <div style="font-size:10px;color:#6e7681;font-weight:500;
                                text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">
                        Başlık
                    </div>
                    <div style="font-size:12px;color:#f0f6fc;font-weight:500">
                        @contact.Title
                    </div>
                </div>
                <div style="padding:16px 20px">
                    <div style="font-size:10px;color:#6e7681;font-weight:500;
                                text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">
                        Telefon Numarası
                    </div>
                    <div style="font-size:12px;color:#22c55e;font-weight:600">
                        @contact.Number
                    </div>
                </div>
            </div>

            <div style="display:flex;align-items:center;justify-content:space-between;
                        padding:12px 16px;background:#0d1117">
                <span style="font-size:11px;color:#6e7681">ID: @contact.ContactId</span>
                <div style="display:flex;gap:8px">
                    <a asp-action="UpdateContact" asp-route-id="@contact.ContactId"
                       style="display:inline-flex;align-items:center;gap:5px;
                              padding:6px 14px;background:#0d2818;color:#22c55e;
                              border:1px solid #22c55e33;border-radius:7px;
                              font-size:11px;font-weight:500;text-decoration:none">
                        <svg width="12" height="12" fill="none" stroke="currentColor"
                             stroke-width="1.5" viewBox="0 0 16 16">
                            <path d="M11 2l3 3-8 8H3v-3l8-8z"/>
                        </svg>
                        Düzenle
                    </a>
                    <form asp-action="DeleteContact" asp-route-id="@contact.ContactId"
                          method="post" style="display:inline"
                          onsubmit="return confirm('Silmek istediğinize emin misiniz?')">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                style="display:inline-flex;align-items:center;gap:5px;
                                       padding:6px 14px;background:#2a0d0d;color:#ef4444;
                                       border:1px solid #ef444433;border-radius:7px;
                                       font-size:11px;font-weight:500;cursor:pointer">
                            <svg width="12" height="12" fill="none" stroke="currentColor"
                                 stroke-width="1.5" viewBox="0 0 16 16">
                                <path d="M3 5h10M6 5V3h4v2M5 5l.5 8h5l.5-8"/>
                            </svg>
                            Sil
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>