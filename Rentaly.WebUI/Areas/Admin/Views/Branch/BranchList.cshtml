@model List<Rentaly.DtoLayer.BranchDtos.ResultBranchDto>

@{
    ViewData["Title"] = "Şube Yönetimi";
    Layout = "~/Views/Admin/Index.cshtml";
}

<div style="padding:20px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid #21262d">
        <div style="display:flex;align-items:center;gap:10px">
            <span style="width:7px;height:7px;background:#22c55e;border-radius:50%;display:inline-block"></span>
            <span style="font-size:14px;font-weight:500;color:#f0f6fc">Şube Yönetimi</span>
            <span style="font-size:10px;background:#0d2818;color:#22c55e;border:1px solid #22c55e33;padding:2px 9px;border-radius:20px">@(Model?.Count ?? 0) şube</span>
        </div>
        <a asp-action="CreateBranch" style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:#22c55e;color:#fff;border-radius:8px;font-size:12px;font-weight:500;text-decoration:none">
            <svg width="13" height="13" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 16 16"><path d="M8 3v10M3 8h10"/></svg>Şube Ekle
        </a>
    </div>

    <div style="background:#161b22;border:1px solid #21262d;border-radius:12px;overflow:hidden">
        <table style="width:100%;border-collapse:collapse;font-size:12px;table-layout:fixed">
            <colgroup>
                <col style="width:44px"/><col style="width:22%"/><col style="width:100px"/><col/><col style="width:148px"/>
            </colgroup>
            <thead>
                <tr style="background:#0d1117;border-bottom:1px solid #21262d">
                    <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;font-weight:500;text-transform:uppercase;letter-spacing:.5px">ID</th>
                    <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;font-weight:500;text-transform:uppercase;letter-spacing:.5px">Şube Adı</th>
                    <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;font-weight:500;text-transform:uppercase;letter-spacing:.5px">Şehir</th>
                    <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;font-weight:500;text-transform:uppercase;letter-spacing:.5px">Adres</th>
                    <th style="text-align:right;padding:10px 16px;font-size:10px;color:#6e7681;font-weight:500;text-transform:uppercase;letter-spacing:.5px">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="5" style="padding:32px;text-align:center;color:#6e7681;font-size:12px">Henüz şube eklenmemiş</td></tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom:1px solid #21262d">
                            <td style="padding:12px 16px;color:#6e7681;font-size:11px">@item.BranchId</td>
                            <td style="padding:12px 16px">
                                <div style="display:flex;align-items:center;gap:8px">
                                    <div style="width:28px;height:28px;background:#0c1f3d;border:1px solid #3b82f633;border-radius:6px;display:flex;align-items:center;justify-content:center">
                                        <svg width="14" height="14" fill="none" stroke="#60a5fa" stroke-width="1.5" viewBox="0 0 16 16"><path d="M8 2a4 4 0 0 0-4 4c0 3 4 8 4 8s4-5 4-8a4 4 0 0 0-4-4z"/><circle cx="8" cy="6" r="1.5"/></svg>
                                    </div>
                                    <span style="font-size:12px;font-weight:500;color:#f0f6fc;overflow:hidden;white-space:nowrap;text-overflow:ellipsis">@item.BranchName</span>
                                </div>
                            </td>
                            <td style="padding:12px 16px">
                                <span style="font-size:11px;background:#0c1f3d;color:#60a5fa;border:1px solid #3b82f633;padding:2px 9px;border-radius:10px">@item.City</span>
                            </td>
                            <td style="padding:12px 16px;font-size:11px;color:#8b949e;overflow:hidden;white-space:nowrap;text-overflow:ellipsis">@item.Address</td>
                            <td style="padding:12px 16px">
                                <div style="display:flex;gap:6px;justify-content:flex-end">
                                    <a asp-action="UpdateBranch" asp-route-id="@item.BranchId" style="display:inline-flex;align-items:center;gap:4px;padding:5px 12px;background:#0d2818;color:#22c55e;border:1px solid #22c55e33;border-radius:7px;font-size:11px;font-weight:500;text-decoration:none;white-space:nowrap">
                                        <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><path d="M11 2l3 3-8 8H3v-3l8-8z"/></svg>Düzenle
                                    </a>
                                    <form asp-action="DeleteBranch" asp-route-id="@item.BranchId" method="post" style="display:inline" onsubmit="return confirm('Emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" style="display:inline-flex;align-items:center;gap:4px;padding:5px 12px;background:#2a0d0d;color:#ef4444;border:1px solid #ef444433;border-radius:7px;font-size:11px;font-weight:500;cursor:pointer;white-space:nowrap">
                                            <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><path d="M3 5h10M6 5V3h4v2M5 5l.5 8h5l.5-8"/></svg>Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>