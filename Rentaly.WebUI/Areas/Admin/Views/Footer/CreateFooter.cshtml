@model Rentaly.DtoLayer.FooterDtos.CreateFooterDto

@{
    ViewData["Title"] = "Footer Ekle";
    Layout = "~/Views/Admin/Index.cshtml";
}

<div style="padding:20px">

    <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px;
                padding-bottom:14px;border-bottom:1px solid #21262d">
        <a asp-action="FooterList"
           style="display:inline-flex;align-items:center;gap:4px;
                  color:#8b949e;font-size:12px;text-decoration:none">
            <svg width="13" height="13" fill="none" stroke="currentColor"
                 stroke-width="1.5" viewBox="0 0 16 16">
                <path d="M10 3L5 8l5 5"/>
            </svg>
            Geri
        </a>
        <span style="color:#30363d;font-size:12px">/</span>
        <span style="font-size:13px;font-weight:500;color:#f0f6fc">Footer İçeriği Ekle</span>
    </div>

    <form asp-action="CreateFooter" method="post">
        @Html.AntiForgeryToken()

        <div style="background:#161b22;border:1px solid #21262d;
                    border-radius:12px;padding:20px">

            <div style="margin-bottom:14px">
                <label style="font-size:11px;color:#8b949e;font-weight:500;
                              display:block;margin-bottom:5px">
                    Açıklama <span style="color:#6e7681">(Description)</span>
                </label>
                <textarea asp-for="Description" rows="4"
                          style="width:100%;background:#0d1117;border:1px solid #30363d;
                                 border-radius:8px;padding:9px 12px;font-size:12px;
                                 color:#c9d1d9;outline:none;resize:vertical;
                                 line-height:1.7;font-family:inherit"
                          placeholder="Where quality meets affordability..."></textarea>
                <span asp-validation-for="Description"
                      style="font-size:11px;color:#ef4444"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px">
                <div>
                    <label style="font-size:11px;color:#8b949e;font-weight:500;
                                  display:block;margin-bottom:5px">
                        Telefon <span style="color:#6e7681">(Number)</span>
                    </label>
                    <div style="display:flex;align-items:center">
                        <div style="background:#0d1117;border:1px solid #30363d;border-right:none;
                                    border-radius:8px 0 0 8px;padding:9px 10px;flex-shrink:0">
                            <svg width="13" height="13" fill="none" stroke="#6e7681"
                                 stroke-width="1.4" viewBox="0 0 16 16">
                                <path d="M2 3a1 1 0 0 1 1-1h2l1 3-1.5 1a9 9 0 0 0 4.5 4.5L11 9l3 1v2a1 1 0 0 1-1 1A13 13 0 0 1 2 3z"/>
                            </svg>
                        </div>
                        <input asp-for="Number"
                               style="flex:1;background:#0d1117;border:1px solid #30363d;
                                      border-left:none;border-radius:0 8px 8px 0;
                                      padding:9px 12px;font-size:12px;color:#c9d1d9;outline:none"
                               placeholder="+1 333 9296"/>
                    </div>
                    <span asp-validation-for="Number"
                          style="font-size:11px;color:#ef4444"></span>
                </div>

                <div>
                    <label style="font-size:11px;color:#8b949e;font-weight:500;
                                  display:block;margin-bottom:5px">
                        E-posta <span style="color:#6e7681">(Email)</span>
                    </label>
                    <div style="display:flex;align-items:center">
                        <div style="background:#0d1117;border:1px solid #30363d;border-right:none;
                                    border-radius:8px 0 0 8px;padding:9px 10px;flex-shrink:0">
                            <svg width="13" height="13" fill="none" stroke="#6e7681"
                                 stroke-width="1.4" viewBox="0 0 16 16">
                                <rect x="2" y="4" width="12" height="8" rx="1.5"/>
                                <path d="M2 4l6 5 6-5"/>
                            </svg>
                        </div>
                        <input asp-for="Email"
                               style="flex:1;background:#0d1117;border:1px solid #30363d;
                                      border-left:none;border-radius:0 8px 8px 0;
                                      padding:9px 12px;font-size:12px;color:#c9d1d9;outline:none"
                               placeholder="contact@example.com"/>
                    </div>
                    <span asp-validation-for="Email"
                          style="font-size:11px;color:#ef4444"></span>
                </div>
            </div>

            <div style="margin-bottom:20px">
                <label style="font-size:11px;color:#8b949e;font-weight:500;
                              display:block;margin-bottom:5px">
                    Adres <span style="color:#6e7681">(Address)</span>
                </label>
                <div style="display:flex;align-items:center">
                    <div style="background:#0d1117;border:1px solid #30363d;border-right:none;
                                border-radius:8px 0 0 8px;padding:9px 10px;flex-shrink:0">
                        <svg width="13" height="13" fill="none" stroke="#6e7681"
                             stroke-width="1.4" viewBox="0 0 16 16">
                            <path d="M8 2a4 4 0 0 0-4 4c0 3 4 8 4 8s4-5 4-8a4 4 0 0 0-4-4z"/>
                            <circle cx="8" cy="6" r="1.5"/>
                        </svg>
                    </div>
                    <input asp-for="Address"
                           style="flex:1;background:#0d1117;border:1px solid #30363d;
                                  border-left:none;border-radius:0 8px 8px 0;
                                  padding:9px 12px;font-size:12px;color:#c9d1d9;outline:none"
                           placeholder="08 W 36th St, New York, NY 10001"/>
                </div>
                <span asp-validation-for="Address"
                      style="font-size:11px;color:#ef4444"></span>
            </div>

            <div style="display:flex;gap:8px">
                <button type="submit"
                        style="padding:9px 24px;background:#22c55e;color:#fff;border:none;
                               border-radius:8px;font-size:12px;font-weight:500;cursor:pointer">
                    Kaydet
                </button>
                <a asp-action="FooterList"
                   style="padding:9px 20px;background:transparent;color:#8b949e;
                          border:1px solid #30363d;border-radius:8px;font-size:12px;
                          text-decoration:none;display:inline-flex;align-items:center">
                    İptal
                </a>
            </div>
        </div>
    </form>
</div>