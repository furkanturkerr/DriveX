@model Rentaly.DtoLayer.CategoryDtos.UpdateCategoryDto

@{
    ViewData["Title"] = "Kategori Güncelle";
    Layout = "~/Views/Admin/Index.cshtml";
}

<div style="padding:20px">

    <div style="display:flex;align-items:center;justify-content:space-between;
                margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid #21262d">
        <div style="display:flex;align-items:center;gap:10px">
            <span style="width:7px;height:7px;background:#22c55e;border-radius:50%;
                         display:inline-block"></span>
            <span style="font-size:14px;font-weight:500;color:#f0f6fc">Kategori Güncelle</span>
        </div>

        <a asp-action="CategoryList"
           style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;
                  background:#21262d;color:#f0f6fc;border-radius:8px;font-size:12px;
                  font-weight:500;text-decoration:none">
            <svg width="13" height="13" fill="none" stroke="currentColor"
                 stroke-width="2" viewBox="0 0 16 16">
                <path d="M10 3 5 8l5 5"/>
            </svg>
            Listeye Dön
        </a>
    </div>

    <div style="max-width:700px;background:#161b22;border:1px solid #21262d;
                border-radius:12px;overflow:hidden">

        <div style="padding:12px 16px;border-bottom:1px solid #21262d;background:#0d1117">
            <span style="font-size:12px;font-weight:500;color:#f0f6fc">Kategori Bilgisi</span>
        </div>

        <form method="post" style="padding:20px">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="CategoryId" />

            <div style="margin-bottom:18px">
                <label asp-for="CategoryName"
                       style="display:block;margin-bottom:8px;font-size:12px;
                              font-weight:500;color:#f0f6fc">
                    Kategori Adı
                </label>

                <input asp-for="CategoryName"
                       placeholder="Kategori adını giriniz"
                       style="width:100%;background:#0d1117;border:1px solid #30363d;
                              color:#f0f6fc;border-radius:8px;padding:12px 14px;
                              font-size:12px;outline:none" />

                <span asp-validation-for="CategoryName"
                      style="display:block;margin-top:6px;font-size:11px;color:#ef4444"></span>
            </div>

            <div style="display:flex;justify-content:space-between;align-items:center;
                        padding-top:8px;border-top:1px solid #21262d">

                <div style="font-size:11px;color:#6e7681">
                    ID: @Model.CategoryId
                </div>

                <div style="display:flex;gap:8px">
                    <a asp-action="CategoryList"
                       style="display:inline-flex;align-items:center;gap:6px;padding:9px 16px;
                              background:#21262d;color:#f0f6fc;border-radius:8px;
                              font-size:12px;font-weight:500;text-decoration:none">
                        Vazgeç
                    </a>

                    <button type="submit"
                            style="display:inline-flex;align-items:center;gap:6px;padding:9px 16px;
                                   background:#22c55e;color:#fff;border:none;border-radius:8px;
                                   font-size:12px;font-weight:500;cursor:pointer">
                        <svg width="13" height="13" fill="none" stroke="#fff"
                             stroke-width="2" viewBox="0 0 16 16">
                            <path d="M11 2l3 3-8 8H3v-3l8-8z"/>
                        </svg>
                        Güncelle
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>