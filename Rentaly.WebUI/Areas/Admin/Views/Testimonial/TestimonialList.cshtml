@model List<Rentaly.DtoLayer.TestimonialDtos.ResultTestimonialDto>

@{
    ViewData["Title"] = "Yorumlar Yönetimi";
    Layout = "~/Views/Admin/Index.cshtml";
}

<div style="padding:20px">

    <div style="display:flex;align-items:center;justify-content:space-between;
                margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid #21262d">
        <div style="display:flex;align-items:center;gap:10px">
            <span style="width:7px;height:7px;background:#22c55e;border-radius:50%;
                         display:inline-block"></span>
            <span style="font-size:14px;font-weight:500;color:#f0f6fc">Yorumlar Yönetimi</span>
            <span style="font-size:10px;background:#0d2818;color:#22c55e;
                         border:1px solid #22c55e33;padding:2px 9px;border-radius:20px">
                @(Model?.Count ?? 0) kayıt
            </span>
        </div>
        <a asp-action="CreateTestimonial"
           style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;
                  background:#22c55e;color:#fff;border-radius:8px;font-size:12px;
                  font-weight:500;text-decoration:none">
            <svg width="13" height="13" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 16 16">
                <path d="M8 3v10M3 8h10"/>
            </svg>
            Yorum Ekle
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div style="text-align:center;padding:52px 20px;background:#161b22;
                    border:1px dashed #30363d;border-radius:12px">
            <svg width="40" height="40" fill="none" stroke="#30363d" stroke-width="1.5"
                 viewBox="0 0 16 16" style="margin:0 auto 14px;display:block">
                <path d="M2 3h12v8H9l-3 2V11H2z"/>
            </svg>
            <div style="font-size:13px;color:#8b949e;margin-bottom:6px">Henüz yorum eklenmemiş</div>
            <div style="font-size:11px;color:#6e7681">Yukarıdaki "Yorum Ekle" butonuna tıklayın</div>
        </div>
    }
    else
    {
        @* KARTLİK ÖNİZLEME *@
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px">
            @foreach (var item in Model.Take(3))
            {
                <div style="position:relative;border-radius:12px;overflow:hidden;
                            min-height:220px;background:#1a1a1a">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="~/images/@item.ImageUrl" alt="@item.NameSurname"
                             style="position:absolute;inset:0;width:100%;height:100%;
                                    object-fit:cover;z-index:0"/>
                    }
                    <div style="position:absolute;inset:0;
                                background:linear-gradient(to bottom,rgba(0,0,0,.45) 0%,rgba(0,0,0,.75) 100%);
                                z-index:1"></div>
                    <div style="position:relative;z-index:2;padding:16px">
                        <div style="text-align:right;margin-bottom:8px">
                            <span style="font-size:28px;color:#22c55e;line-height:1">"</span>
                        </div>
                        <div style="font-size:12px;font-weight:700;color:#fff;margin-bottom:8px">
                            @item.Title
                        </div>
                        <div style="font-size:10px;color:rgba(255,255,255,.72);
                                    line-height:1.6;margin-bottom:12px;
                                    display:-webkit-box;-webkit-line-clamp:4;
                                    -webkit-box-orient:vertical;overflow:hidden">
                            @item.Description
                        </div>
                        <div style="display:flex;align-items:center;gap:6px">
                            <span style="display:inline-block;width:18px;height:1.5px;
                                         background:#22c55e"></span>
                            <span style="font-size:10px;font-weight:600;color:#fff">
                                @item.NameSurname
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* TABLO *@
        <div style="background:#161b22;border:1px solid #21262d;
                    border-radius:12px;overflow:hidden">
            <table style="width:100%;border-collapse:collapse;font-size:12px;table-layout:fixed">
                <colgroup>
                    <col style="width:44px"/>
                    <col style="width:80px"/>
                    <col style="width:18%"/>
                    <col style="width:18%"/>
                    <col/>
                    <col style="width:148px"/>
                </colgroup>
                <thead>
                    <tr style="background:#0d1117;border-bottom:1px solid #21262d">
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">
                            ID
                        </th>
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">
                            Görsel
                        </th>
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">
                            Ad Soyad
                        </th>
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">
                            Başlık
                        </th>
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">
                            Açıklama
                        </th>
                        <th style="text-align:right;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">
                            İşlem
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom:1px solid #21262d">

                            <td style="padding:12px 16px;color:#6e7681;font-size:11px">
                                @item.TestimonialId
                            </td>

                            <td style="padding:12px 16px">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <div style="width:38px;height:38px;border-radius:50%;
                                                overflow:hidden;border:2px solid #22c55e33">
                                        <img src="~/images/@item.ImageUrl"
                                             alt="@item.NameSurname"
                                             style="width:100%;height:100%;object-fit:cover"/>
                                    </div>
                                }
                                else
                                {
                                    <div style="width:38px;height:38px;border-radius:50%;
                                                background:#21262d;border:2px solid #30363d;
                                                display:flex;align-items:center;
                                                justify-content:center">
                                        <span style="font-size:11px;font-weight:600;color:#6e7681">
                                            @(item.NameSurname?.Length > 0
                                                ? item.NameSurname.Substring(0,1).ToUpper()
                                                : "?")
                                        </span>
                                    </div>
                                }
                            </td>

                            <td style="padding:12px 16px">
                                <div style="font-size:12px;font-weight:500;color:#f0f6fc;
                                            overflow:hidden;white-space:nowrap;text-overflow:ellipsis">
                                    @item.NameSurname
                                </div>
                            </td>

                            <td style="padding:12px 16px">
                                <div style="font-size:11px;color:#c9d1d9;overflow:hidden;
                                            white-space:nowrap;text-overflow:ellipsis">
                                    @item.Title
                                </div>
                            </td>

                            <td style="padding:12px 16px">
                                <div style="font-size:11px;color:#8b949e;overflow:hidden;
                                            white-space:nowrap;text-overflow:ellipsis">
                                    @item.Description
                                </div>
                            </td>

                            <td style="padding:12px 16px">
                                <div style="display:flex;gap:6px;justify-content:flex-end">
                                    <a asp-action="UpdateTestimonial"
                                       asp-route-id="@item.TestimonialId"
                                       style="display:inline-flex;align-items:center;gap:4px;
                                              padding:5px 12px;background:#0d2818;color:#22c55e;
                                              border:1px solid #22c55e33;border-radius:7px;
                                              font-size:11px;font-weight:500;text-decoration:none;
                                              white-space:nowrap">
                                        <svg width="11" height="11" fill="none"
                                             stroke="currentColor" stroke-width="1.5"
                                             viewBox="0 0 16 16">
                                            <path d="M11 2l3 3-8 8H3v-3l8-8z"/>
                                        </svg>
                                        Düzenle
                                    </a>
                                    <form asp-action="DeleteTestimonial"
                                          asp-route-id="@item.TestimonialId"
                                          method="post" style="display:inline"
                                          onsubmit="return confirm('Silmek istediğinize emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                style="display:inline-flex;align-items:center;
                                                       gap:4px;padding:5px 12px;background:#2a0d0d;
                                                       color:#ef4444;border:1px solid #ef444433;
                                                       border-radius:7px;font-size:11px;
                                                       font-weight:500;cursor:pointer;
                                                       white-space:nowrap">
                                            <svg width="11" height="11" fill="none"
                                                 stroke="currentColor" stroke-width="1.5"
                                                 viewBox="0 0 16 16">
                                                <path d="M3 5h10M6 5V3h4v2M5 5l.5 8h5l.5-8"/>
                                            </svg>
                                            Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>