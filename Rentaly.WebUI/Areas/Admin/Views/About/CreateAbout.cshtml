@model Rentaly.DtoLayer.AboutDtos.CreateAboutDto

@{
    ViewData["Title"] = "Hakkımızda Ekle";
    Layout = "~/Views/Admin/Index.cshtml";
}

<div class="container-fluid px-4 py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h3 class="fw-bold text-white mb-1">Hakkımızda Ekle</h3>
            <p class="text-secondary mb-0">Ana sayfada gösterilecek hakkımızda metnini oluşturun.</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 bg-dark text-white">
                <div class="card-header bg-transparent border-bottom border-secondary py-3">
                    <h5 class="mb-0 fw-semibold">Yeni Hakkımızda İçeriği</h5>
                </div>

                <div class="card-body p-4">
                    <form method="post">
                        <div class="mb-4">
                            <label asp-for="AboutText" class="form-label fw-semibold text-light">Hakkımızda Yazısı</label>
                            <textarea asp-for="AboutText"
                                      class="form-control bg-black text-white border-secondary rounded-4 p-3"
                                      rows="10"
                                      placeholder="Şirketinizin hizmet anlayışını, araç filonuzu ve müşterilere sunduğunuz avantajları açıklayın..."></textarea>
                            <span asp-validation-for="AboutText" class="text-danger small"></span>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-success rounded-pill px-4">
                                <i class="fas fa-save me-2"></i>Kaydet
                            </button>

                            <a href="/Admin/About/AboutList" class="btn btn-outline-light rounded-pill px-4">
                                <i class="fas fa-arrow-left me-2"></i>Geri Dön
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 bg-dark text-white mt-4">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-3">İçerik Önerisi</h6>
                    <p class="text-secondary mb-0" style="line-height:1.8;">
                        Bu alanda firmanızın güvenilirliği, araç çeşitliliği, müşteri memnuniyeti ve sunduğunuz hizmet kalitesi gibi
                        öne çıkan noktaları sade ve güçlü bir dille anlatmanız daha profesyonel bir görünüm sağlar.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>