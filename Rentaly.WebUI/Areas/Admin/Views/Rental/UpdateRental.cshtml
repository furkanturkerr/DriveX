@model Rentaly.DtoLayer.RentalDtos.UpdateRentalDto

@{
    ViewData["Title"] = "Rezervasyon Güncelle";
    Layout = "~/Views/Admin/Index.cshtml";
}

<div style="padding:24px;">

    <div style="display:flex;align-items:flex-start;justify-content:space-between;
                gap:16px;margin-bottom:24px;padding-bottom:18px;border-bottom:1px solid #1a2332;flex-wrap:wrap;">
        <div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <span style="width:8px;height:8px;background:#22c55e;border-radius:50%;display:inline-block;"></span>
                <span style="font-size:13px;color:#8fa3bf;font-weight:600;letter-spacing:.2px;">Rezervasyon Yönetimi</span>
            </div>

            <h1 style="margin:0;font-size:38px;line-height:1.1;font-weight:800;color:#f8fafc;">
                Rezervasyon Güncelle
            </h1>

            <p style="margin:10px 0 0;color:#7f8ea3;font-size:15px;line-height:1.6;">
                Rezervasyon durumunu güncelleyin ve gerekli admin notunu ekleyin.
            </p>
        </div>

        <div style="background:#0f1724;border:1px solid #1d2a3b;border-radius:16px;
                    padding:14px 18px;min-width:150px;text-align:center;box-shadow:0 10px 30px rgba(0,0,0,.18);">
            <div style="font-size:12px;color:#7f8ea3;margin-bottom:6px;">Rezervasyon ID</div>
            <div style="font-size:28px;font-weight:800;color:#f8fafc;">#@Model.RentalId</div>
        </div>
    </div>

    <form method="post" asp-action="UpdateRental">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="RentalId" />

        <div style="display:grid;grid-template-columns:minmax(0,2fr) minmax(280px,1fr);gap:22px;align-items:start;">

            <div style="background:#0f1724;
                        border:1px solid #1d2a3b;border-radius:22px;padding:26px;
                        box-shadow:0 14px 35px rgba(0,0,0,.22);">

                <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;
                            margin-bottom:24px;flex-wrap:wrap;">
                    <div>
                        <div style="font-size:13px;color:#7f8ea3;margin-bottom:6px;">İşlem Paneli</div>
                        <div style="font-size:22px;font-weight:800;color:#f8fafc;">Durum ve Not Yönetimi</div>
                    </div>

                    <div style="display:inline-flex;align-items:center;gap:8px;
                                padding:9px 14px;border-radius:999px;
                                background:#0b1320;border:1px solid rgba(34,197,94,.22);
                                color:#22c55e;font-size:12px;font-weight:700;">
                        <span style="width:8px;height:8px;border-radius:50%;background:#22c55e;display:inline-block;"></span>
                        Admin İşlemi
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr;gap:18px;">

                    <div style="background:#0b1320;border:1px solid #1b2838;border-radius:16px;padding:18px;">
                        <label style="display:block;color:#b8c4d6;font-size:12px;font-weight:700;
                                      margin-bottom:10px;letter-spacing:.4px;text-transform:uppercase;">
                            Rezervasyon Durumu
                        </label>

                        <select asp-for="Status"
                                style="width:100%;height:52px;background:#09111c;color:#f8fafc;
                                       border:1px solid #2a3a4d;border-radius:14px;padding:0 14px;
                                       font-size:14px;outline:none;box-shadow:none;">
                            <option value="0">Beklemede</option>
                            <option value="1">Onaylandı</option>
                            <option value="2">Reddedildi</option>
                            <option value="3">Teslim</option>
                            <option value="4">Tamamlandı</option>
                            <option value="5">İptal</option>
                        </select>
                    </div>

                    <div style="background:#0b1320;border:1px solid #1b2838;border-radius:16px;padding:18px;">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px;flex-wrap:wrap;">
                            <label style="display:block;color:#b8c4d6;font-size:12px;font-weight:700;
                                          letter-spacing:.4px;text-transform:uppercase;">
                                Admin Notu
                            </label>
                            <span style="font-size:11px;color:#6f8299;">İsteğe bağlı</span>
                        </div>

                        <textarea asp-for="AdminNote"
                                  placeholder="Rezervasyonla ilgili açıklama, onay notu veya red sebebi yazın..."
                                  style="width:100%;min-height:220px;background:#09111c;color:#e5edf7;
                                         border:1px solid #2a3a4d;border-radius:14px;padding:16px;
                                         font-size:14px;line-height:1.7;resize:vertical;outline:none;
                                         box-sizing:border-box;"></textarea>
                    </div>
                </div>

                <div style="display:flex;justify-content:space-between;align-items:center;
                            margin-top:24px;padding-top:20px;border-top:1px solid #1a2332;
                            gap:12px;flex-wrap:wrap;">

                    <a asp-action="RentalList"
                       style="display:inline-flex;align-items:center;justify-content:center;
                              padding:12px 18px;background:#182231;color:#e5edf7;
                              border:1px solid #2a3a4d;border-radius:14px;
                              text-decoration:none;font-size:14px;font-weight:700;
                              transition:all .2s ease;">
                        ← Geri Dön
                    </a>

                    <button type="submit"
                            style="display:inline-flex;align-items:center;justify-content:center;
                                   padding:13px 24px;background:#22c55e;color:#ffffff;
                                   border:1px solid #22c55e;border-radius:14px;font-size:14px;
                                   font-weight:800;cursor:pointer;
                                   box-shadow:0 10px 24px rgba(34,197,94,.22);">
                        Güncellemeyi Kaydet
                    </button>
                </div>
            </div>

            <div style="display:flex;flex-direction:column;gap:16px;">

                <div style="background:#0f1724;border:1px solid #1d2a3b;border-radius:20px;
                            padding:20px;box-shadow:0 10px 28px rgba(0,0,0,.16);">
                    <div style="font-size:15px;font-weight:700;color:#f8fafc;margin-bottom:16px;">
                        Durum Rehberi
                    </div>

                    <div style="display:flex;flex-direction:column;gap:14px;">

                        <div style="display:flex;align-items:center;gap:12px;">
                            <span style="width:10px;height:10px;border-radius:50%;background:#f59e0b;display:inline-block;"></span>
                            <span style="font-size:14px;color:#e5edf7;font-weight:600;">Beklemede</span>
                        </div>

                        <div style="display:flex;align-items:center;gap:12px;">
                            <span style="width:10px;height:10px;border-radius:50%;background:#22c55e;display:inline-block;"></span>
                            <span style="font-size:14px;color:#e5edf7;font-weight:600;">Onaylandı</span>
                        </div>

                        <div style="display:flex;align-items:center;gap:12px;">
                            <span style="width:10px;height:10px;border-radius:50%;background:#ef4444;display:inline-block;"></span>
                            <span style="font-size:14px;color:#e5edf7;font-weight:600;">Reddedildi / İptal</span>
                        </div>

                        <div style="display:flex;align-items:center;gap:12px;">
                            <span style="width:10px;height:10px;border-radius:50%;background:#3b82f6;display:inline-block;"></span>
                            <span style="font-size:14px;color:#e5edf7;font-weight:600;">Teslim</span>
                        </div>

                        <div style="display:flex;align-items:center;gap:12px;">
                            <span style="width:10px;height:10px;border-radius:50%;background:#a855f7;display:inline-block;"></span>
                            <span style="font-size:14px;color:#e5edf7;font-weight:600;">Tamamlandı</span>
                        </div>
                    </div>
                </div>

                <div style="background:#0f1724;border:1px solid #1d2a3b;border-radius:20px;padding:20px;">
                    <div style="font-size:15px;font-weight:700;color:#f8fafc;margin-bottom:10px;">
                        Admin İpucu
                    </div>
                    <div style="font-size:14px;line-height:1.8;color:#c4d0df;">
                        Red veya iptal durumlarında kısa ama net bir açıklama girmeniz,
                        ileride rezervasyon geçmişini incelerken büyük kolaylık sağlar.
                    </div>
                </div>

            </div>
        </div>
    </form>
</div>