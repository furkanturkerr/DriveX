@model Rentaly.DtoLayer.ServiceDtos.CreateServiceDto

@{
    ViewData["Title"] = "Servis Ekle";
    Layout = "~/Views/Admin/Index.cshtml";
}

<div style="padding:20px">

    <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px;
                padding-bottom:14px;border-bottom:1px solid #21262d">
        <a asp-action="Index"
           style="display:inline-flex;align-items:center;gap:4px;
                  color:#8b949e;font-size:12px;text-decoration:none">
            <svg width="13" height="13" fill="none" stroke="currentColor"
                 stroke-width="1.5" viewBox="0 0 16 16">
                <path d="M10 3L5 8l5 5"/>
            </svg>
            Geri
        </a>
        <span style="color:#30363d;font-size:12px">/</span>
        <span style="font-size:13px;font-weight:500;color:#f0f6fc">Yeni Servis Ekle</span>
    </div>

    <form method="post">
        @Html.AntiForgeryToken()

        <div style="background:#161b22;border:1px solid #21262d;border-radius:12px;padding:20px">

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px">
                <div>
                    <label style="font-size:11px;color:#8b949e;font-weight:500;
                                  display:block;margin-bottom:5px">
                        Başlık <span style="color:#6e7681">(Title)</span>
                    </label>
                    <input asp-for="Title"
                           style="width:100%;background:#0d1117;border:1px solid #30363d;
                                  border-radius:8px;padding:9px 12px;font-size:12px;
                                  color:#c9d1d9;outline:none"
                           placeholder="First class services"/>
                    <span asp-validation-for="Title" style="font-size:11px;color:#ef4444"></span>
                </div>

                <div>
                    <label style="font-size:11px;color:#8b949e;font-weight:500;
                                  display:block;margin-bottom:5px">
                        İkon Yolu <span style="color:#6e7681">(IconUrl)</span>
                    </label>
                    <div style="display:flex;align-items:center">
                        <div style="background:#0d1117;border:1px solid #30363d;border-right:none;
                                    border-radius:8px 0 0 8px;padding:9px 10px;
                                    font-size:11px;color:#6e7681;white-space:nowrap">
                            /icons/
                        </div>
                        <input asp-for="IconUrl"
                               style="flex:1;background:#0d1117;border:1px solid #30363d;
                                      border-left:none;border-radius:0 8px 8px 0;
                                      padding:9px 12px;font-size:12px;color:#c9d1d9;outline:none"
                               placeholder="trophy.svg"/>
                    </div>
                    <span asp-validation-for="IconUrl" style="font-size:11px;color:#ef4444"></span>
                </div>
            </div>

            <div style="margin-bottom:14px">
                <label style="font-size:11px;color:#8b949e;font-weight:500;
                              display:block;margin-bottom:5px">
                    Açıklama <span style="color:#6e7681">(Description)</span>
                </label>
                <textarea asp-for="Description" rows="4"
                          style="width:100%;background:#0d1117;border:1px solid #30363d;
                                 border-radius:8px;padding:9px 12px;font-size:12px;
                                 color:#c9d1d9;outline:none;resize:vertical;
                                 line-height:1.7;font-family:inherit"
                          placeholder="Where luxury meets exceptional care..."></textarea>
                <span asp-validation-for="Description" style="font-size:11px;color:#ef4444"></span>
            </div>

            <div style="margin-bottom:20px">
                <label style="font-size:11px;color:#8b949e;font-weight:500;
                              display:block;margin-bottom:8px">
                    Konum <span style="color:#6e7681">(Position)</span>
                </label>
                <div style="display:flex;gap:10px">
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;
                                  padding:10px 16px;background:#0d1117;border:1px solid #30363d;
                                  border-radius:8px;flex:1" id="lbl-left">
                        <input type="radio" asp-for="Position" value="Left"
                               onchange="highlightPos()"
                               style="accent-color:#22c55e;width:14px;height:14px"/>
                        <div>
                            <div style="font-size:12px;font-weight:500;color:#c9d1d9">Sol (Left)</div>
                            <div style="font-size:10px;color:#6e7681;margin-top:2px">
                                İkon solda, metin sağda
                            </div>
                        </div>
                    </label>
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;
                                  padding:10px 16px;background:#0d1117;border:1px solid #30363d;
                                  border-radius:8px;flex:1" id="lbl-right">
                        <input type="radio" asp-for="Position" value="Right"
                               onchange="highlightPos()"
                               style="accent-color:#22c55e;width:14px;height:14px"/>
                        <div>
                            <div style="font-size:12px;font-weight:500;color:#c9d1d9">Sağ (Right)</div>
                            <div style="font-size:10px;color:#6e7681;margin-top:2px">
                                İkon sağda, metin solda
                            </div>
                        </div>
                    </label>
                </div>
                <span asp-validation-for="Position" style="font-size:11px;color:#ef4444"></span>
            </div>

            <div style="display:flex;gap:8px">
                <button
                        style="padding:9px 24px;background:#22c55e;color:#fff;border:none;
                               border-radius:8px;font-size:12px;font-weight:500;cursor:pointer">
                    Kaydet
                </button>
                <a asp-action="ServiceList"
                   style="padding:9px 20px;background:transparent;color:#8b949e;
                          border:1px solid #30363d;border-radius:8px;font-size:12px;
                          text-decoration:none;display:inline-flex;align-items:center">
                    İptal
                </a>
            </div>
        </div>
    </form>
</div>

<script>
function highlightPos() {
    const left  = document.querySelector('input[value="Left"]');
    const right = document.querySelector('input[value="Right"]');
    document.getElementById('lbl-left').style.borderColor  = left.checked  ? '#22c55e' : '#30363d';
    document.getElementById('lbl-right').style.borderColor = right.checked ? '#22c55e' : '#30363d';
}
</script>