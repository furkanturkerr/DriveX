@model List<Rentaly.DtoLayer.ServiceDtos.ResultServiceDto>

@{
    ViewData["Title"] = "Servis Yönetimi";
    Layout = "~/Views/Admin/Index.cshtml";
    var leftItems  = Model?.Where(x => x.Position == "fadeInLeft").ToList()  ?? new();
    var rightItems = Model?.Where(x => x.Position == "fadeInRight").ToList() ?? new();
}

<div style="padding:20px">

    <div style="display:flex;align-items:center;justify-content:space-between;
                margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid #21262d">
        <div style="display:flex;align-items:center;gap:10px">
            <span style="width:7px;height:7px;background:#22c55e;border-radius:50%;
                         display:inline-block"></span>
            <span style="font-size:14px;font-weight:500;color:#f0f6fc">Servis Yönetimi</span>
            <span style="font-size:10px;background:#0d2818;color:#22c55e;
                         border:1px solid #22c55e33;padding:2px 9px;border-radius:20px">
                @(Model?.Count ?? 0) kayıt
            </span>
        </div>
        <a asp-action="CreateService"
           style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;
                  background:#22c55e;color:#fff;border-radius:8px;font-size:12px;
                  font-weight:500;text-decoration:none">
            <svg width="13" height="13" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 16 16">
                <path d="M8 3v10M3 8h10"/>
            </svg>
            Servis Ekle
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div style="text-align:center;padding:52px 20px;background:#161b22;
                    border:1px dashed #30363d;border-radius:12px">
            <svg width="40" height="40" fill="none" stroke="#30363d" stroke-width="1.5"
                 viewBox="0 0 16 16" style="margin:0 auto 14px;display:block">
                <rect x="2" y="2" width="12" height="12" rx="2"/>
                <path d="M5 6h6M5 9h4"/>
            </svg>
            <div style="font-size:13px;color:#8b949e;margin-bottom:6px">Henüz servis eklenmemiş</div>
            <div style="font-size:11px;color:#6e7681">Yukarıdaki "Servis Ekle" butonuna tıklayın</div>
        </div>
    }
    else
    {
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">

            <!-- SOL -->
            <div>
                <div style="display:flex;align-items:center;gap:6px;margin-bottom:10px">
                    <div style="width:3px;height:16px;background:#22c55e;border-radius:2px"></div>
                    <span style="font-size:11px;font-weight:500;color:#8b949e;
                                 text-transform:uppercase;letter-spacing:.6px">
                        Sol Kolon (Left)
                    </span>
                    <span style="font-size:10px;background:#0d2818;color:#22c55e;
                                 border:1px solid #22c55e33;padding:1px 7px;border-radius:10px">
                        @leftItems.Count
                    </span>
                </div>
                @foreach (var item in leftItems)
                {
                    <div style="background:#161b22;border:1px solid #21262d;border-radius:12px;
                                overflow:hidden;margin-bottom:10px">
                        <div style="display:flex;align-items:flex-start;gap:12px;padding:14px 16px">
                            <div style="width:38px;height:38px;background:#22c55e;border-radius:8px;
                                        flex-shrink:0;display:flex;align-items:center;
                                        justify-content:center">
                                <img src="~/icons/@item.IconUrl" alt=""
                                     style="width:20px;height:20px;filter:brightness(0) invert(1)"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='block'"/>
                                <svg style="display:none" width="18" height="18" fill="none"
                                     stroke="#fff" stroke-width="1.5" viewBox="0 0 16 16">
                                    <circle cx="8" cy="8" r="5"/>
                                    <path d="M8 5v4M8 11v.5"/>
                                </svg>
                            </div>
                            <div style="flex:1;min-width:0">
                                <div style="font-size:13px;font-weight:500;color:#f0f6fc;
                                            margin-bottom:4px">@item.Title</div>
                                <div style="font-size:11px;color:#8b949e;line-height:1.6;
                                            display:-webkit-box;-webkit-line-clamp:2;
                                            -webkit-box-orient:vertical;overflow:hidden">
                                    @item.Description
                                </div>
                            </div>
                        </div>
                        <div style="display:flex;align-items:center;justify-content:space-between;
                                    padding:9px 16px;border-top:1px solid #21262d;background:#0d1117">
                            <span style="font-size:10px;color:#6e7681">ID: @item.ServiceId</span>
                            <div style="display:flex;gap:8px">
                                <a asp-action="UpdateService" asp-route-id="@item.ServiceId"
                                   style="display:inline-flex;align-items:center;gap:5px;
                                          padding:5px 12px;background:#161b22;color:#22c55e;
                                          border:1px solid #22c55e33;border-radius:7px;
                                          font-size:11px;font-weight:500;text-decoration:none">
                                    <svg width="11" height="11" fill="none" stroke="currentColor"
                                         stroke-width="1.5" viewBox="0 0 16 16">
                                        <path d="M11 2l3 3-8 8H3v-3l8-8z"/>
                                    </svg>
                                    Düzenle
                                </a>
                                <form asp-action="DeleteService" asp-route-id="@item.ServiceId"
                                      method="post" style="display:inline"
                                      onsubmit="return confirm('Silmek istediğinize emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            style="display:inline-flex;align-items:center;gap:5px;
                                                   padding:5px 12px;background:#161b22;color:#ef4444;
                                                   border:1px solid #ef444433;border-radius:7px;
                                                   font-size:11px;font-weight:500;cursor:pointer">
                                        <svg width="11" height="11" fill="none" stroke="currentColor"
                                             stroke-width="1.5" viewBox="0 0 16 16">
                                            <path d="M3 5h10M6 5V3h4v2M5 5l.5 8h5l.5-8"/>
                                        </svg>
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- SAĞ -->
            <div>
                <div style="display:flex;align-items:center;gap:6px;margin-bottom:10px">
                    <div style="width:3px;height:16px;background:#3b82f6;border-radius:2px"></div>
                    <span style="font-size:11px;font-weight:500;color:#8b949e;
                                 text-transform:uppercase;letter-spacing:.6px">
                        Sağ Kolon (Right)
                    </span>
                    <span style="font-size:10px;background:#0c1f3d;color:#60a5fa;
                                 border:1px solid #3b82f633;padding:1px 7px;border-radius:10px">
                        @rightItems.Count
                    </span>
                </div>
                @foreach (var item in rightItems)
                {
                    <div style="background:#161b22;border:1px solid #21262d;border-radius:12px;
                                overflow:hidden;margin-bottom:10px">
                        <div style="display:flex;align-items:flex-start;gap:12px;padding:14px 16px;
                                    flex-direction:row-reverse;text-align:right">
                            <div style="width:38px;height:38px;background:#22c55e;border-radius:8px;
                                        flex-shrink:0;display:flex;align-items:center;
                                        justify-content:center">
                                <img src="~/icons/@item.IconUrl" alt=""
                                     style="width:20px;height:20px;filter:brightness(0) invert(1)"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='block'"/>
                                <svg style="display:none" width="18" height="18" fill="none"
                                     stroke="#fff" stroke-width="1.5" viewBox="0 0 16 16">
                                    <circle cx="8" cy="8" r="5"/>
                                    <path d="M8 5v4M8 11v.5"/>
                                </svg>
                            </div>
                            <div style="flex:1;min-width:0">
                                <div style="font-size:13px;font-weight:500;color:#f0f6fc;
                                            margin-bottom:4px">@item.Title</div>
                                <div style="font-size:11px;color:#8b949e;line-height:1.6;
                                            display:-webkit-box;-webkit-line-clamp:2;
                                            -webkit-box-orient:vertical;overflow:hidden">
                                    @item.Description
                                </div>
                            </div>
                        </div>
                        <div style="display:flex;align-items:center;justify-content:space-between;
                                    padding:9px 16px;border-top:1px solid #21262d;background:#0d1117">
                            <span style="font-size:10px;color:#6e7681">ID: @item.ServiceId</span>
                            <div style="display:flex;gap:8px">
                                <a asp-action="UpdateService" asp-route-id="@item.ServiceId"
                                   style="display:inline-flex;align-items:center;gap:5px;
                                          padding:5px 12px;background:#161b22;color:#22c55e;
                                          border:1px solid #22c55e33;border-radius:7px;
                                          font-size:11px;font-weight:500;text-decoration:none">
                                    <svg width="11" height="11" fill="none" stroke="currentColor"
                                         stroke-width="1.5" viewBox="0 0 16 16">
                                        <path d="M11 2l3 3-8 8H3v-3l8-8z"/>
                                    </svg>
                                    Düzenle
                                </a>
                                <form asp-action="DeleteService" asp-route-id="@item.ServiceId"
                                      method="post" style="display:inline"
                                      onsubmit="return confirm('Silmek istediğinize emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            style="display:inline-flex;align-items:center;gap:5px;
                                                   padding:5px 12px;background:#161b22;color:#ef4444;
                                                   border:1px solid #ef444433;border-radius:7px;
                                                   font-size:11px;font-weight:500;cursor:pointer">
                                        <svg width="11" height="11" fill="none" stroke="currentColor"
                                             stroke-width="1.5" viewBox="0 0 16 16">
                                            <path d="M3 5h10M6 5V3h4v2M5 5l.5 8h5l.5-8"/>
                                        </svg>
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

        </div>
    }
</div>