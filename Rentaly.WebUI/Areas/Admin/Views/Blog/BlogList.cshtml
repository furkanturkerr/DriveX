@model List<Rentaly.DtoLayer.BlogDtos.ResultBlogDto>

@{
    ViewData["Title"] = "Blog Yönetimi";
    Layout = "~/Views/Admin/Index.cshtml";
}

<div style="padding:20px">

    <div style="display:flex;align-items:center;justify-content:space-between;
                margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid #21262d">
        <div style="display:flex;align-items:center;gap:10px">
            <span style="width:7px;height:7px;background:#22c55e;border-radius:50%;
                         display:inline-block"></span>
            <span style="font-size:14px;font-weight:500;color:#f0f6fc">Blog Yönetimi</span>
            <span style="font-size:10px;background:#0d2818;color:#22c55e;
                         border:1px solid #22c55e33;padding:2px 9px;border-radius:20px">
                @(Model?.Count ?? 0) kayıt
            </span>
        </div>
        <a asp-action="CreateBlog"
           style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;
                  background:#22c55e;color:#fff;border-radius:8px;font-size:12px;
                  font-weight:500;text-decoration:none">
            <svg width="13" height="13" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 16 16">
                <path d="M8 3v10M3 8h10"/>
            </svg>
            Blog Ekle
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div style="text-align:center;padding:52px 20px;background:#161b22;
                    border:1px dashed #30363d;border-radius:12px">
            <svg width="40" height="40" fill="none" stroke="#30363d" stroke-width="1.5"
                 viewBox="0 0 16 16" style="margin:0 auto 14px;display:block">
                <rect x="2" y="2" width="12" height="12" rx="2"/>
                <path d="M5 6h6M5 9h4"/>
            </svg>
            <div style="font-size:13px;color:#8b949e;margin-bottom:6px">Henüz blog eklenmemiş</div>
            <div style="font-size:11px;color:#6e7681">Yukarıdaki "Blog Ekle" butonuna tıklayın</div>
        </div>
    }
    else
    {
        @* KARTLİK ÖNİZLEME *@
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px">
            @foreach (var item in Model.Take(3))
            {
                <div style="background:#161b22;border:1px solid #21262d;
                            border-radius:12px;overflow:hidden">
                    <div style="position:relative;height:140px;background:#21262d;overflow:hidden">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Title"
                                 style="width:100%;height:100%;object-fit:cover"/>
                        }
                        <div style="position:absolute;top:10px;left:10px;
                                    background:#22c55e;border-radius:7px;
                                    padding:4px 8px;text-align:center;min-width:36px">
                            <div style="font-size:14px;font-weight:700;color:#fff;line-height:1">
                                @item.DateCreated.Day
                            </div>
                            <div style="font-size:8px;font-weight:600;color:#fff;
                                        letter-spacing:.5px;text-transform:uppercase">
                                @item.DateCreated.ToString("MMM")
                            </div>
                        </div>
                        <div style="position:absolute;top:10px;right:10px">
                            @if (item.IsStatus)
                            {
                                <span style="font-size:9px;background:#0d2818;color:#22c55e;
                                             border:1px solid #22c55e33;padding:2px 7px;
                                             border-radius:10px;font-weight:500">Yayında</span>
                            }
                            else
                            {
                                <span style="font-size:9px;background:#2a0d0d;color:#ef4444;
                                             border:1px solid #ef444433;padding:2px 7px;
                                             border-radius:10px;font-weight:500">Taslak</span>
                            }
                        </div>
                    </div>
                    <div style="padding:12px 14px">
                        <div style="font-size:12px;font-weight:600;color:#f0f6fc;
                                    margin-bottom:6px;overflow:hidden;white-space:nowrap;
                                    text-overflow:ellipsis">
                            @item.Title
                        </div>
                        <div style="font-size:10px;color:#8b949e;line-height:1.6;
                                    display:-webkit-box;-webkit-line-clamp:2;
                                    -webkit-box-orient:vertical;overflow:hidden">
                            @item.Description
                        </div>
                    </div>
                </div>
            }
        </div>

        @* TABLO *@
        <div style="background:#161b22;border:1px solid #21262d;
                    border-radius:12px;overflow:hidden">
            <table style="width:100%;border-collapse:collapse;font-size:12px;table-layout:fixed">
                <colgroup>
                    <col style="width:44px"/>
                    <col style="width:70px"/>
                    <col style="width:20%"/>
                    <col/>
                    <col style="width:90px"/>
                    <col style="width:80px"/>
                    <col style="width:148px"/>
                </colgroup>
                <thead>
                    <tr style="background:#0d1117;border-bottom:1px solid #21262d">
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">ID</th>
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">Görsel</th>
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">Başlık</th>
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">Açıklama</th>
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">Tarih</th>
                        <th style="text-align:left;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">Durum</th>
                        <th style="text-align:right;padding:10px 16px;font-size:10px;color:#6e7681;
                                   font-weight:500;text-transform:uppercase;letter-spacing:.5px">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom:1px solid #21262d">

                            <td style="padding:12px 16px;color:#6e7681;font-size:11px">
                                @item.BlogId
                            </td>

                            <td style="padding:12px 16px">
                                <div style="width:44px;height:34px;border-radius:6px;
                                            overflow:hidden;background:#21262d">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt=""
                                             style="width:100%;height:100%;object-fit:cover"/>
                                    }
                                </div>
                            </td>

                            <td style="padding:12px 16px">
                                <div style="font-size:12px;font-weight:500;color:#f0f6fc;
                                            overflow:hidden;white-space:nowrap;text-overflow:ellipsis">
                                    @item.Title
                                </div>
                            </td>

                            <td style="padding:12px 16px">
                                <div style="font-size:11px;color:#8b949e;overflow:hidden;
                                            white-space:nowrap;text-overflow:ellipsis">
                                    @item.Description
                                </div>
                            </td>

                            <td style="padding:12px 16px">
                                <div style="font-size:11px;color:#8b949e">
                                    @item.DateCreated.ToString("dd MMM yyyy")
                                </div>
                            </td>

                            <td style="padding:12px 16px">
                                @if (item.IsStatus)
                                {
                                    <span style="font-size:10px;background:#0d2818;color:#22c55e;
                                                 border:1px solid #22c55e33;padding:2px 9px;
                                                 border-radius:10px;font-weight:500;white-space:nowrap">
                                        Yayında
                                    </span>
                                }
                                else
                                {
                                    <span style="font-size:10px;background:#2a0d0d;color:#ef4444;
                                                 border:1px solid #ef444433;padding:2px 9px;
                                                 border-radius:10px;font-weight:500;white-space:nowrap">
                                        Taslak
                                    </span>
                                }
                            </td>

                            <td style="padding:12px 16px">
                                <div style="display:flex;gap:6px;justify-content:flex-end">
                                    <a asp-action="UpdateBlog" asp-route-id="@item.BlogId"
                                       style="display:inline-flex;align-items:center;gap:4px;
                                              padding:5px 12px;background:#0d2818;color:#22c55e;
                                              border:1px solid #22c55e33;border-radius:7px;
                                              font-size:11px;font-weight:500;text-decoration:none;
                                              white-space:nowrap">
                                        <svg width="11" height="11" fill="none" stroke="currentColor"
                                             stroke-width="1.5" viewBox="0 0 16 16">
                                            <path d="M11 2l3 3-8 8H3v-3l8-8z"/>
                                        </svg>
                                        Düzenle
                                    </a>
                                    <form asp-action="DeleteBlog" asp-route-id="@item.BlogId"
                                          method="post" style="display:inline"
                                          onsubmit="return confirm('Silmek istediğinize emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                style="display:inline-flex;align-items:center;
                                                       gap:4px;padding:5px 12px;background:#2a0d0d;
                                                       color:#ef4444;border:1px solid #ef444433;
                                                       border-radius:7px;font-size:11px;
                                                       font-weight:500;cursor:pointer;white-space:nowrap">
                                            <svg width="11" height="11" fill="none" stroke="currentColor"
                                                 stroke-width="1.5" viewBox="0 0 16 16">
                                                <path d="M3 5h10M6 5V3h4v2M5 5l.5 8h5l.5-8"/>
                                            </svg>
                                            Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>