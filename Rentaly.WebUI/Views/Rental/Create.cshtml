@using System.Globalization
@model Rentaly.DtoLayer.RentalDtos.CreateRentalDto

@{
Layout = null;
var car      = ViewBag.Car as Rentaly.DtoLayer.CarDtos.ResultCarWithCategory;
var branches = ViewBag.Branches as List<Rentaly.DtoLayer.BranchDtos.ResultBranchDto>;
}

<!DOCTYPE html>
<html lang="tr">
@await Component.InvokeAsync("_DefaultHeadComponentPartial")
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.css">
<style>
    .wizard-wrap { max-width: 960px; margin: 0 auto; padding: 40px 20px 80px; }

    .stepper { display:flex; align-items:center; justify-content:center; margin-bottom:50px; }
    .step-item { display:flex; flex-direction:column; align-items:center; position:relative; flex:1; }
    .step-item:not(:last-child)::after {
        content:''; position:absolute; top:20px; left:50%;
        width:100%; height:2px; background:#e0e0e0; z-index:0;
    }
    .step-item.done:not(:last-child)::after { background:#28a745; }
    .step-circle {
        width:42px; height:42px; border-radius:50%;
        border:2px solid #e0e0e0; background:#fff;
        display:flex; align-items:center; justify-content:center;
        font-weight:700; font-size:15px; color:#aaa;
        position:relative; z-index:1;
    }
    .step-item.active .step-circle { border-color:#28a745; color:#28a745; }
    .step-item.done   .step-circle { background:#28a745; border-color:#28a745; color:#fff; }
    .step-label { font-size:12px; color:#aaa; margin-top:8px; font-weight:600; text-transform:uppercase; }
    .step-item.active .step-label,
    .step-item.done   .step-label { color:#28a745; }

    .step-panel { display:none; }
    .step-panel.active { display:block; }

    .car-card {
        display:flex; gap:24px; background:#f8f9fa;
        border-radius:10px; padding:20px 24px;
        margin-bottom:30px; border:1px solid #e8e8e8;
    }
    .car-card img { width:160px; object-fit:contain; flex-shrink:0; }
    .car-card h4  { font-size:20px; font-weight:700; margin:0 0 8px; }
    .car-card .attrs { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:10px; }
    .car-card .attr  { background:#fff; border:1px solid #ddd; border-radius:4px; padding:3px 10px; font-size:12px; color:#555; }
    .car-card .price { font-size:24px; font-weight:700; color:#28a745; }
    .car-card .price span { font-size:13px; color:#aaa; font-weight:400; }

    .field-group { margin-bottom:20px; }
    .field-group label { display:block; font-size:11px; font-weight:700; color:#888; text-transform:uppercase; margin-bottom:6px; }
    .field-group input,
    .field-group select {
        width:100%; padding:11px 14px;
        border:1px solid #e0e0e0; border-radius:6px;
        font-size:14px; color:#333; background:#fafafa;
        box-sizing:border-box;
    }
    .field-group input:focus,
    .field-group select:focus { border-color:#28a745; outline:none; background:#fff; }
    .field-error { color:#dc3545; font-size:11px; margin-top:3px; display:block; }

    .info-box { background:#f8f9fa; border-radius:8px; padding:16px 20px; margin-bottom:20px; }
    .info-row { display:flex; justify-content:space-between; padding:7px 0; border-bottom:1px dashed #e0e0e0; font-size:14px; color:#555; }
    .info-row:last-child { border:none; }
    .info-row strong { color:#222; }

    .summary-box { border:1px solid #e0e0e0; border-radius:10px; overflow:hidden; position:sticky; top:20px; }
    .summary-box .head { background:#28a745; color:#fff; padding:14px 20px; font-weight:700; font-size:15px; }
    .summary-box .body { padding:20px; }
    .sum-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px dashed #eee; font-size:13px; color:#666; gap:10px; }
    .sum-row:last-child { border:none; }
    .sum-row strong { color:#222; font-size:14px; text-align:right; }
    .sum-total { display:flex; justify-content:space-between; padding:14px 0 0; font-size:20px; font-weight:700; color:#28a745; }

    .section-label {
        font-size:13px; font-weight:700; color:#222; text-transform:uppercase;
        margin:0 0 18px; padding-bottom:8px; border-bottom:2px solid #28a745;
        display:inline-block;
    }
    .panel-title { font-size:22px; font-weight:700; color:#222; margin-bottom:4px; }
    .panel-sub   { font-size:14px; color:#888; margin-bottom:28px; }

    .btn-row { display:flex; justify-content:space-between; align-items:center; margin-top:30px; gap:15px; flex-wrap:wrap; }
    .btn-next   { background:#28a745; color:#fff; border:none; border-radius:6px; padding:13px 36px; font-size:15px; font-weight:700; cursor:pointer; }
    .btn-next:hover { opacity:.88; }
    .btn-back   { background:#f5f5f5; color:#555; border:1px solid #ddd; border-radius:6px; padding:13px 36px; font-size:15px; font-weight:600; cursor:pointer; text-decoration:none; }
    .btn-back:hover { background:#e8e8e8; }
    .btn-submit { background:#28a745; color:#fff; border:none; border-radius:6px; padding:14px 40px; font-size:16px; font-weight:700; cursor:pointer; }
    .btn-submit:hover { opacity:.88; }

    /* Flatpickr dolu günler */
    .flatpickr-day.booked {
        background: #ffe0e0 !important;
        color: #cc0000 !important;
        text-decoration: line-through;
        cursor: not-allowed !important;
    }
    .flatpickr-day.booked:hover {
        background: #ffe0e0 !important;
    }

    @@media (max-width:991px) {
        .car-card { flex-direction:column; }
        .car-card img { width:100%; max-width:260px; }
    }
</style>

<body>
<div id="wrapper">

    @await Component.InvokeAsync("_DefaultNavbarComponentPartial")

    <div class="no-bottom no-top zebra" id="content">
        <div id="top"></div>

        <section id="subheader" class="jarallax text-light">
            <img src="~/Rentaly/RentalyHTML/images/background/2.jpg" class="jarallax-img" alt="">
            <div class="center-y relative text-center">
                <div class="container">
                    <div class="col-md-12 text-center">
                        <h1>Araç Kiralama</h1>
                        <p>Birkaç adımda rezervasyonunuzu tamamlayın</p>
                    </div>
                </div>
            </div>
        </section>

        <section>
            <div class="container">
                <div class="wizard-wrap">

                    <div class="stepper">
                        <div class="step-item active" id="si-1">
                            <div class="step-circle">1</div>
                            <div class="step-label">Tarih & Şube</div>
                        </div>
                        <div class="step-item" id="si-2">
                            <div class="step-circle">2</div>
                            <div class="step-label">Bilgiler & Özet</div>
                        </div>
                    </div>

                    @if (car != null)
                    {
                    <div class="car-card">
                        <img src="@car.ImageUrl" alt="@car.BrandName @car.ModelName">
                        <div>
                            <h4>@car.BrandName @car.ModelName</h4>
                            <div class="attrs">
                                <span class="attr">@car.CategoryName</span>
                                <span class="attr">@car.FuelType</span>
                                <span class="attr">@car.SeatCount Koltuk</span>
                                <span class="attr">@car.Year</span>
                            </div>
                            <div class="price">₺@car.DailyPrice <span>/ gün</span></div>
                        </div>
                    </div>
                    }

                    <form asp-action="Create" asp-controller="Rental" method="post" id="rental-form">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="CarId" />
                        <input type="hidden" id="hidden-pickup"  name="PickupDate" />
                        <input type="hidden" id="hidden-dropoff" name="DropoffDate" />

                        <!-- PANEL 1 -->
                        <div class="step-panel active" id="panel-1">
                            <div class="panel-title">Tarih & Şube Seçin</div>
                            <div class="panel-sub">Alış ve teslim bilgilerinizi girin</div>

                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="field-group">
                                        <label>Alış Şubesi</label>
                                        <select name="PickupBranchId">
                                            <option value="">Şube Seçin</option>
                                            @foreach (var b in branches ?? new())
                                            {
                                            <option value="@b.BranchId">@b.BranchName</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="field-group">
                                        <label>Teslim Şubesi</label>
                                        <select name="DropoffBranchId">
                                            <option value="">Şube Seçin</option>
                                            @foreach (var b in branches ?? new())
                                            {
                                            <option value="@b.BranchId">@b.BranchName</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="field-group">
                                        <label>Alış Tarihi</label>
                                        <input type="text" id="input-pickup" placeholder="Tarih seçin" readonly />
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="field-group">
                                        <label>Teslim Tarihi</label>
                                        <input type="text" id="input-dropoff" placeholder="Tarih seçin" readonly />
                                    </div>
                                </div>
                            </div>

                            <div class="info-box" id="price-preview" style="display:none">
                                <div class="info-row">
                                    <span>Kiralama Süresi</span>
                                    <strong><span id="calc-days">0</span> gün</strong>
                                </div>
                                <div class="info-row">
                                    <span>Tahmini Toplam</span>
                                    <strong style="color:#28a745;font-size:18px" id="calc-total">₺0</strong>
                                </div>
                            </div>

                            <div class="btn-row">
                                <a asp-action="CarList" asp-controller="Car" class="btn-back">← Araçlara Dön</a>
                                <button type="button" class="btn-next" onclick="goStep2()">Devam Et →</button>
                            </div>
                        </div>

                        <!-- PANEL 2 -->
                        <div class="step-panel" id="panel-2">
                            <div class="panel-title">Kişisel Bilgiler</div>
                            <div class="panel-sub">Bilgilerinizi doldurun ve rezervasyonu tamamlayın</div>

                            <div class="row">
                                <div class="col-lg-8">
                                    <div class="section-label">Kişisel Bilgiler</div>
                                    <div class="row">
                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>Ad</label>
                                                <input asp-for="FirstName" placeholder="Adınız">
                                                <span asp-validation-for="FirstName" class="field-error"></span>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>Soyad</label>
                                                <input asp-for="LastName" placeholder="Soyadınız">
                                                <span asp-validation-for="LastName" class="field-error"></span>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>TC Kimlik No</label>
                                                <input asp-for="IdentityNumber" placeholder="xxxxxxxxxxx" maxlength="11">
                                                <span asp-validation-for="IdentityNumber" class="field-error"></span>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>Doğum Tarihi</label>
                                                <input asp-for="BirthDate" type="date">
                                                <span asp-validation-for="BirthDate" class="field-error"></span>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>Telefon</label>
                                                <input asp-for="Phone" placeholder="05xx xxx xx xx">
                                                <span asp-validation-for="Phone" class="field-error"></span>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>E-posta</label>
                                                <input asp-for="Email" type="email" placeholder="ornek@email.com">
                                                <span asp-validation-for="Email" class="field-error"></span>
                                            </div>
                                        </div>
                                        <div class="col-lg-12">
                                            <div class="field-group">
                                                <label>Ehliyet No</label>
                                                <input asp-for="LicenseNumber" placeholder="Ehliyet numaranız">
                                                <span asp-validation-for="LicenseNumber" class="field-error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-4">
                                    <div class="section-label">Rezervasyon Özeti</div>
                                    <div class="summary-box">
                                        <div class="head">📋 Özet</div>
                                        <div class="body">
                                            <div class="sum-row">
                                                <span>Araç</span>
                                                <strong>@(car != null ? $"{car.BrandName} {car.ModelName}" : "—")</strong>
                                            </div>
                                            <div class="sum-row">
                                                <span>Alış</span>
                                                <strong id="sum-pickup">—</strong>
                                            </div>
                                            <div class="sum-row">
                                                <span>Teslim</span>
                                                <strong id="sum-dropoff">—</strong>
                                            </div>
                                            <div class="sum-row">
                                                <span>Süre</span>
                                                <strong><span id="sum-days">—</span> gün</strong>
                                            </div>
                                            <div class="sum-row">
                                                <span>Günlük Fiyat</span>
                                                <strong>₺@(car?.DailyPrice ?? 0)</strong>
                                            </div>
                                            <div class="sum-total">
                                                <span>Toplam</span>
                                                <span id="sum-total">—</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="btn-row">
                                <button type="button" class="btn-back" onclick="goPanel(1)">← Geri</button>
                                <button type="submit" class="btn-submit">Rezervasyonu Tamamla ✓</button>
                            </div>
                        </div>
                    </form>

                </div>
            </div>
        </section>
    </div>

    <a href="#" id="back-to-top"></a>
    @await Component.InvokeAsync("_DefaultFooterComponentPartial")
</div>

<script src="~/Rentaly/RentalyHTML/js/plugins.js"></script>
<script src="~/Rentaly/RentalyHTML/js/designesia.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/l10n/tr.js"></script>

<script>
    const DAILY_PRICE   = @((car?.DailyPrice ?? 0).ToString(CultureInfo.InvariantCulture));
    const hiddenPickup  = document.getElementById('hidden-pickup');
    const hiddenDropoff = document.getElementById('hidden-dropoff');

    let bookedRanges = [];
    let fpPickup, fpDropoff;

    async function loadBookedDates() {
        const carId = document.querySelector('input[name="CarId"]').value;
        const res   = await fetch(`/Rental/GetBookedDates?carId=${carId}`);
        bookedRanges = await res.json();
        initPickers();
    }

    // Verilen Date nesnesinin dolu aralıkta olup olmadığını kontrol et
    function isBooked(date) {
        const str = date.toISOString().split('T')[0];
        return bookedRanges.some(r => str >= r.start && str < r.end);
    }

    function syncHidden() {
        const p = fpPickup?.selectedDates[0];
        const d = fpDropoff?.selectedDates[0];
        hiddenPickup.value  = p ? p.toISOString().split('T')[0] + 'T09:00:00' : '';
        hiddenDropoff.value = d ? d.toISOString().split('T')[0] + 'T09:00:00' : '';
    }

    function updatePreview() {
        const p = hiddenPickup.value;
        const d = hiddenDropoff.value;
        if (!p || !d) { document.getElementById('price-preview').style.display = 'none'; return; }

        const days = Math.ceil((new Date(d) - new Date(p)) / 86400000);
        if (days <= 0) { document.getElementById('price-preview').style.display = 'none'; return; }

        const total = days * DAILY_PRICE;
        document.getElementById('calc-days').textContent  = days;
        document.getElementById('calc-total').textContent = '₺' + total.toLocaleString('tr-TR');
        document.getElementById('price-preview').style.display = 'block';

        document.getElementById('sum-days').textContent    = days;
        document.getElementById('sum-total').textContent   = '₺' + total.toLocaleString('tr-TR');
        document.getElementById('sum-pickup').textContent  = new Date(p).toLocaleDateString('tr-TR');
        document.getElementById('sum-dropoff').textContent = new Date(d).toLocaleDateString('tr-TR');
    }

    function initPickers() {
        const today = new Date();
        today.setHours(0, 0, 0, 0);

        // Dolu günleri flatpickr'ın disable listesine çevir
        const disabledDates = bookedRanges.map(r => ({ from: r.start, to: r.end }));

        fpPickup = flatpickr('#input-pickup', {
            locale: 'tr',
            dateFormat: 'd.m.Y',
            minDate: 'today',
            disable: disabledDates,
            onDayCreate: function(dObj, dStr, fp, dayElem) {
                if (isBooked(dayElem.dateObj)) {
                    dayElem.classList.add('booked');
                    dayElem.title = 'Bu tarih dolu';
                }
            },
            onChange: function(selectedDates) {
                if (!selectedDates[0]) return;

                const minDropoff = new Date(selectedDates[0]);
                minDropoff.setDate(minDropoff.getDate() + 1);
                fpDropoff.set('minDate', minDropoff);

                // Eğer seçili dropoff bu yeni min'den önceyse sıfırla
                const curDropoff = fpDropoff.selectedDates[0];
                if (curDropoff && curDropoff <= selectedDates[0]) {
                    fpDropoff.clear();
                }

                syncHidden();
                updatePreview();
            }
        });

        fpDropoff = flatpickr('#input-dropoff', {
            locale: 'tr',
            dateFormat: 'd.m.Y',
            minDate: new Date(today.getTime() + 86400000),
            disable: disabledDates,
            onDayCreate: function(dObj, dStr, fp, dayElem) {
                if (isBooked(dayElem.dateObj)) {
                    dayElem.classList.add('booked');
                    dayElem.title = 'Bu tarih dolu';
                }
            },
            onChange: function() {
                syncHidden();
                updatePreview();
            }
        });
    }

    function goPanel(n) {
        document.querySelectorAll('.step-panel').forEach((p, i) =>
            p.classList.toggle('active', i + 1 === n));
        document.querySelectorAll('.step-item').forEach((s, i) => {
            s.classList.remove('active', 'done');
            if (i + 1 < n) s.classList.add('done');
            if (i + 1 === n) s.classList.add('active');
        });
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function goStep2() {
        if (!document.querySelector('select[name="PickupBranchId"]').value)
            return alert('Lütfen alış şubesini seçin.');
        if (!document.querySelector('select[name="DropoffBranchId"]').value)
            return alert('Lütfen teslim şubesini seçin.');
        if (!hiddenPickup.value)
            return alert('Lütfen alış tarihini seçin.');
        if (!hiddenDropoff.value)
            return alert('Lütfen teslim tarihini seçin.');

        goPanel(2);
    }

    loadBookedDates();
</script>

</body>
</html>