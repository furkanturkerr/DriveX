@using System.Globalization
@model Rentaly.DtoLayer.RentalDtos.CreateRentalDto

@{
    Layout = null; 
    var car = ViewBag.Car as Rentaly.DtoLayer.CarDtos.ResultCarWithCategory; 
    var branches = ViewBag.Branches as List<Rentaly.DtoLayer.BranchDtos.ResultBranchDto>;
    var today = DateTime.Today; 
    var tomorrow = today.AddDays(1);

  string[] hours =
  {
      "09:00", "10:00", "11:00", "12:00", "13:00",
      "14:00", "15:00", "16:00", "17:00", "18:00"
  };
}

<!DOCTYPE html>
<html lang="tr">
@await Component.InvokeAsync("_DefaultHeadComponentPartial")

<style>
    .wizard-wrap { max-width: 960px; margin: 0 auto; padding: 40px 20px 80px; }

    .stepper { display: flex; align-items: center; justify-content: center; margin-bottom: 50px; }
    .step-item { display: flex; flex-direction: column; align-items: center; position: relative; flex: 1; }
    .step-item:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 20px;
        left: 50%;
        width: 100%;
        height: 2px;
        background: #e0e0e0;
        z-index: 0;
        transition: background .4s;
    }
    .step-item.done:not(:last-child)::after { background: #28a745; }
    .step-circle {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        border: 2px solid #e0e0e0;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 15px;
        color: #aaa;
        position: relative;
        z-index: 1;
        transition: all .3s;
    }
    .step-item.active .step-circle {
        border-color: #28a745;
        color: #28a745;
        box-shadow: 0 0 0 4px rgba(40,167,69,.15);
    }
    .step-item.done .step-circle {
        background: #28a745;
        border-color: #28a745;
        color: #fff;
    }
    .step-label {
        font-size: 12px;
        color: #aaa;
        margin-top: 8px;
        font-weight: 600;
        letter-spacing: .5px;
        text-transform: uppercase;
    }
    .step-item.active .step-label,
    .step-item.done .step-label { color: #28a745; }

    .step-panel { display: none; animation: fadeUp .3s ease; }
    .step-panel.active { display: block; }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .car-summary-card {
        display: flex;
        align-items: center;
        gap: 24px;
        background: #f8f9fa;
        border-radius: 10px;
        padding: 20px 24px;
        margin-bottom: 30px;
        border: 1px solid #e8e8e8;
    }
    .car-summary-card img {
        width: 160px;
        object-fit: contain;
        flex-shrink: 0;
    }
    .car-summary-card h4 {
        font-size: 20px;
        font-weight: 700;
        margin: 0 0 8px;
    }
    .car-summary-card .attrs {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 10px;
    }
    .car-summary-card .attr {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 3px 10px;
        font-size: 12px;
        color: #555;
    }
    .car-summary-card .price {
        font-size: 24px;
        font-weight: 700;
        color: #28a745;
    }
    .car-summary-card .price span {
        font-size: 13px;
        color: #aaa;
        font-weight: 400;
    }

    .info-box {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 16px 20px;
        margin-bottom: 20px;
    }
    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 7px 0;
        border-bottom: 1px dashed #e0e0e0;
        font-size: 14px;
        color: #555;
    }
    .info-row:last-child { border: none; }
    .info-row strong { color: #222; }

    .field-group { margin-bottom: 20px; }
    .field-group label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        color: #888;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: 6px;
    }
    .field-group input,
    .field-group select {
        width: 100%;
        padding: 11px 14px;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        font-size: 14px;
        color: #333;
        background: #fafafa;
        transition: border .2s;
        box-sizing: border-box;
    }
    .field-group input:focus,
    .field-group select:focus {
        border-color: #28a745;
        outline: none;
        background: #fff;
    }
    .field-error {
        color: #dc3545;
        font-size: 11px;
        margin-top: 3px;
        display: block;
    }

    .summary-box {
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        overflow: hidden;
        position: sticky;
        top: 20px;
    }
    .summary-box .head {
        background: #28a745;
        color: #fff;
        padding: 14px 20px;
        font-weight: 700;
        font-size: 15px;
    }
    .summary-box .body { padding: 20px; }
    .sum-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px dashed #eee;
        font-size: 13px;
        color: #666;
        gap: 10px;
    }
    .sum-row:last-child { border: none; }
    .sum-row strong { color: #222; font-size: 14px; text-align: right; }
    .sum-total {
        display: flex;
        justify-content: space-between;
        padding: 14px 0 0;
        font-size: 20px;
        font-weight: 700;
        color: #28a745;
    }

    .btn-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 30px;
        gap: 15px;
        flex-wrap: wrap;
    }
    .btn-next {
        background: #28a745;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 13px 36px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: opacity .2s;
    }
    .btn-next:hover { opacity: .88; }
    .btn-back {
        background: #f5f5f5;
        color: #555;
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 13px 36px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
        text-decoration: none;
    }
    .btn-back:hover { background: #e8e8e8; }
    .btn-submit {
        background: #28a745;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 14px 40px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: opacity .2s;
    }
    .btn-submit:hover { opacity: .88; }

    .time-select-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .time-btn {
        padding: 7px 12px;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        color: #555;
        background: #fff;
        cursor: pointer;
        transition: all .15s;
    }
    .time-btn:hover {
        border-color: #28a745;
        color: #28a745;
        background: #f0fff4;
    }
    .time-btn.active {
        background: #28a745;
        color: #fff;
        border-color: #28a745;
    }

    .section-label {
        font-size: 13px;
        font-weight: 700;
        color: #222;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0 0 18px;
        padding-bottom: 8px;
        border-bottom: 2px solid #28a745;
        display: inline-block;
    }
    .panel-title {
        font-size: 22px;
        font-weight: 700;
        color: #222;
        margin-bottom: 4px;
    }
    .panel-sub {
        font-size: 14px;
        color: #888;
        margin-bottom: 28px;
    }

    .date-input {
        height: 48px;
    }

    @@media (max-width: 991px) {
        .car-summary-card {
            flex-direction: column;
            align-items: flex-start;
        }

        .car-summary-card img {
            width: 100%;
            max-width: 260px;
        }
    }
</style>

<body>
<div id="wrapper">

    @await Component.InvokeAsync("_DefaultNavbarComponentPartial")

    <div class="no-bottom no-top zebra" id="content">
        <div id="top"></div>

        <section id="subheader" class="jarallax text-light">
            <img src="~/Rentaly/RentalyHTML/images/background/2.jpg" class="jarallax-img" alt="">
            <div class="center-y relative text-center">
                <div class="container">
                    <div class="col-md-12 text-center">
                        <h1>Araç Kiralama</h1>
                        <p>Birkaç adımda rezervasyonunuzu tamamlayın</p>
                    </div>
                </div>
            </div>
        </section>

        <section>
            <div class="container">
                <div class="wizard-wrap">

                    <div class="stepper">
                        <div class="step-item active" id="si-1">
                            <div class="step-circle">1</div>
                            <div class="step-label">Tarih & Şube</div>
                        </div>
                        <div class="step-item" id="si-2">
                            <div class="step-circle">2</div>
                            <div class="step-label">Bilgiler & Özet</div>
                        </div>
                    </div>

                    @if (car != null)
                    {
                    <div class="car-summary-card">
                        <img src="@car.ImageUrl" alt="@car.BrandName @car.ModelName">
                        <div>
                            <h4>@car.BrandName @car.ModelName</h4>
                            <div class="attrs">
                                <span class="attr">@car.CategoryName</span>
                                <span class="attr">@car.FuelType</span>
                                <span class="attr">@car.SeatCount Koltuk</span>
                                <span class="attr">@car.Year</span>
                            </div>
                            <div class="price">₺@car.DailyPrice <span>/ gün</span></div>
                        </div>
                    </div>
                    }

                    <form asp-action="Create" asp-controller="Rental" method="post" id="rental-form">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="CarId" />

                        <!-- DTO'ya gidecek gerçek DateTime alanları -->
                        <input type="hidden" asp-for="PickupDate" id="pickup-date">
                        <input type="hidden" asp-for="DropoffDate" id="dropoff-date">

                        <div class="step-panel active" id="panel-1">
                            <div class="panel-title">Tarih & Şube Seçin</div>
                            <div class="panel-sub">Alış ve teslim bilgilerinizi girin</div>

                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="field-group">
                                        <label>Alış Şubesi</label>
                                        <select asp-for="PickupBranchId">
                                            <option value="">Şube Seçin</option>
                                            @if (branches != null)
                                            {
                                            @foreach (var b in branches)
                                            {
                                            <option value="@b.BranchId">@b.BranchName</option>
                                            }
                                            }
                                        </select>
                                        <span asp-validation-for="PickupBranchId" class="field-error"></span>
                                    </div>
                                </div>

                                <div class="col-lg-6">
                                    <div class="field-group">
                                        <label>Teslim Şubesi</label>
                                        <select asp-for="DropoffBranchId">
                                            <option value="">Şube Seçin</option>
                                            @if (branches != null)
                                            {
                                            @foreach (var b in branches)
                                            {
                                            <option value="@b.BranchId">@b.BranchName</option>
                                            }
                                            }
                                        </select>
                                        <span asp-validation-for="DropoffBranchId" class="field-error"></span>
                                    </div>
                                </div>

                                <div class="col-lg-6">
                                    <div class="field-group">
                                        <label>Alış Tarihi</label>
                                        <input type="date"
                                               id="pickup-date-only"
                                               class="date-input"
                                               value="@today.ToString("yyyy-MM-dd")"
                                               min="@today.ToString("yyyy-MM-dd")" />
                                        <span asp-validation-for="PickupDate" class="field-error"></span>
                                    </div>

                                    <div class="field-group">
                                        <label>Alış Saati</label>
                                        <div class="time-select-wrap" id="pickup-time-wrap">
                                            @foreach (var h in hours)
                                            {
                                            <button type="button" class="time-btn @(h == "09:00" ? "active" : "")" data-target="pickup" data-time="@h">@h</button>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-6">
                                    <div class="field-group">
                                        <label>Teslim Tarihi</label>
                                        <input type="date"
                                               id="dropoff-date-only"
                                               class="date-input"
                                               value="@tomorrow.ToString("yyyy-MM-dd")"
                                               min="@tomorrow.ToString("yyyy-MM-dd")" />
                                        <span asp-validation-for="DropoffDate" class="field-error"></span>
                                    </div>

                                    <div class="field-group">
                                        <label>Teslim Saati</label>
                                        <div class="time-select-wrap" id="dropoff-time-wrap">
                                            @foreach (var h in hours)
                                            {
                                            <button type="button" class="time-btn @(h == "09:00" ? "active" : "")" data-target="dropoff" data-time="@h">@h</button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="info-box" id="price-preview" style="display:none;">
                                <div class="info-row">
                                    <span>Kiralama Süresi</span>
                                    <strong><span id="calc-days">0</span> gün</strong>
                                </div>
                                <div class="info-row">
                                    <span>Tahmini Toplam</span>
                                    <strong style="color:#28a745; font-size:18px;" id="calc-total">₺0</strong>
                                </div>
                            </div>

                            <div class="btn-row">
                                <a asp-action="CarList" asp-controller="Car" class="btn-back">← Araçlara Dön</a>
                                <button type="button" class="btn-next" onclick="goStep2()">Devam Et →</button>
                            </div>
                        </div>

                        <div class="step-panel" id="panel-2">
                            <div class="panel-title">Kişisel Bilgiler</div>
                            <div class="panel-sub">Bilgilerinizi doldurun ve rezervasyonu tamamlayın</div>

                            <div class="row">
                                <div class="col-lg-8">
                                    <div class="section-label">Kişisel Bilgiler</div>
                                    <div class="row">
                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>Ad</label>
                                                <input asp-for="FirstName" placeholder="Adınız">
                                                <span asp-validation-for="FirstName" class="field-error"></span>
                                            </div>
                                        </div>

                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>Soyad</label>
                                                <input asp-for="LastName" placeholder="Soyadınız">
                                                <span asp-validation-for="LastName" class="field-error"></span>
                                            </div>
                                        </div>

                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>TC Kimlik No</label>
                                                <input asp-for="IdentityNumber" placeholder="xxxxxxxxxxx" maxlength="11">
                                                <span asp-validation-for="IdentityNumber" class="field-error"></span>
                                            </div>
                                        </div>

                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>Doğum Tarihi</label>
                                                <input asp-for="BirthDate" type="date">
                                                <span asp-validation-for="BirthDate" class="field-error"></span>
                                            </div>
                                        </div>

                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>Telefon</label>
                                                <input asp-for="Phone" placeholder="05xx xxx xx xx">
                                                <span asp-validation-for="Phone" class="field-error"></span>
                                            </div>
                                        </div>

                                        <div class="col-lg-6">
                                            <div class="field-group">
                                                <label>E-posta</label>
                                                <input asp-for="Email" type="email" placeholder="ornek@email.com">
                                                <span asp-validation-for="Email" class="field-error"></span>
                                            </div>
                                        </div>

                                        <div class="col-lg-12">
                                            <div class="field-group">
                                                <label>Ehliyet No</label>
                                                <input asp-for="LicenseNumber" placeholder="Ehliyet numaranız">
                                                <span asp-validation-for="LicenseNumber" class="field-error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-4">
                                    <div class="section-label">Rezervasyon Özeti</div>
                                    <div class="summary-box">
                                        <div class="head">📋 Özet</div>
                                        <div class="body">
                                            <div class="sum-row">
                                                <span>Araç</span>
                                                <strong>@(car != null ? $"{car.BrandName} {car.ModelName}" : "—")</strong>
                                            </div>
                                            <div class="sum-row">
                                                <span>Alış</span>
                                                <strong id="sum-pickup">—</strong>
                                            </div>
                                            <div class="sum-row">
                                                <span>Teslim</span>
                                                <strong id="sum-dropoff">—</strong>
                                            </div>
                                            <div class="sum-row">
                                                <span>Süre</span>
                                                <strong><span id="sum-days">—</span> gün</strong>
                                            </div>
                                            <div class="sum-row">
                                                <span>Günlük Fiyat</span>
                                                <strong>₺@(car?.DailyPrice ?? 0)</strong>
                                            </div>
                                            <div class="sum-total">
                                                <span>Toplam</span>
                                                <span id="sum-total">—</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="btn-row">
                                <button type="button" class="btn-back" onclick="goPanel(1)">← Geri</button>
                                <button type="submit" class="btn-submit">Rezervasyonu Tamamla ✓</button>
                            </div>
                        </div>
                    </form>

                </div>
            </div>
        </section>
    </div>

    <a href="#" id="back-to-top"></a>
    @await Component.InvokeAsync("_DefaultFooterComponentPartial")
</div>

<script src="~/Rentaly/RentalyHTML/js/plugins.js"></script>
<script src="~/Rentaly/RentalyHTML/js/designesia.js"></script>

<script>
    const DAILY_PRICE = Number('@((car?.DailyPrice ?? 0).ToString(CultureInfo.InvariantCulture))');

    const pickupHidden = document.getElementById('pickup-date');
    const dropoffHidden = document.getElementById('dropoff-date');

    const pickupDateOnly = document.getElementById('pickup-date-only');
    const dropoffDateOnly = document.getElementById('dropoff-date-only');

    let pickupTime = '09:00';
    let dropoffTime = '09:00';

    function combineDateAndTime(dateValue, timeValue) {
        return `${dateValue}T${timeValue}:00`;
    }

    function formatSummaryDate(value) {
        if (!value) return '—';
        const d = new Date(value);
        if (isNaN(d.getTime())) return '—';

        return d.toLocaleString('tr-TR', {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function syncDropoffMin() {
        if (!pickupDateOnly.value) return;

        const pickup = new Date(pickupDateOnly.value + 'T00:00:00');
        const minDropoff = new Date(pickup);
        minDropoff.setDate(minDropoff.getDate() + 1);

        const year = minDropoff.getFullYear();
        const month = String(minDropoff.getMonth() + 1).padStart(2, '0');
        const day = String(minDropoff.getDate()).padStart(2, '0');
        const minDropoffStr = `${year}-${month}-${day}`;

        dropoffDateOnly.min = minDropoffStr;

        if (!dropoffDateOnly.value || dropoffDateOnly.value < minDropoffStr) {
            dropoffDateOnly.value = minDropoffStr;
        }
    }

    function syncHiddenDates() {
        pickupHidden.value = combineDateAndTime(pickupDateOnly.value, pickupTime);
        dropoffHidden.value = combineDateAndTime(dropoffDateOnly.value, dropoffTime);
    }

    function clearSummary() {
        document.getElementById('price-preview').style.display = 'none';
        document.getElementById('calc-days').textContent = '0';
        document.getElementById('calc-total').textContent = '₺0';
        document.getElementById('sum-days').textContent = '—';
        document.getElementById('sum-total').textContent = '—';
        document.getElementById('sum-pickup').textContent = '—';
        document.getElementById('sum-dropoff').textContent = '—';
    }

    function calcPrice() {
        const p = pickupHidden.value;
        const d = dropoffHidden.value;

        if (!p || !d) {
            clearSummary();
            return;
        }

        const pickup = new Date(p);
        const dropoff = new Date(d);

        if (isNaN(pickup.getTime()) || isNaN(dropoff.getTime()) || dropoff <= pickup) {
            clearSummary();
            return;
        }

        const msDiff = dropoff - pickup;
        const days = Math.ceil(msDiff / 86400000);

        if (days <= 0) {
            clearSummary();
            return;
        }

        const total = days * DAILY_PRICE;

        document.getElementById('calc-days').textContent = days;
        document.getElementById('calc-total').textContent = '₺' + total.toLocaleString('tr-TR');
        document.getElementById('price-preview').style.display = 'block';

        document.getElementById('sum-days').textContent = days;
        document.getElementById('sum-total').textContent = '₺' + total.toLocaleString('tr-TR');
        document.getElementById('sum-pickup').textContent = formatSummaryDate(p);
        document.getElementById('sum-dropoff').textContent = formatSummaryDate(d);
    }

    function goPanel(n) {
        document.querySelectorAll('.step-panel').forEach((p, i) => {
            p.classList.toggle('active', i + 1 === n);
        });

        document.querySelectorAll('.step-item').forEach((s, i) => {
            s.classList.remove('active', 'done');
            if (i + 1 < n) s.classList.add('done');
            if (i + 1 === n) s.classList.add('active');
        });

        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function goStep2() {
        const pb = document.querySelector('select[name="PickupBranchId"]').value;
        const db = document.querySelector('select[name="DropoffBranchId"]').value;
        const p = pickupHidden.value;
        const d = dropoffHidden.value;

        if (!pb) {
            alert('Lütfen alış şubesini seçin.');
            return;
        }

        if (!db) {
            alert('Lütfen teslim şubesini seçin.');
            return;
        }

        if (!pickupDateOnly.value) {
            alert('Lütfen alış tarihini seçin.');
            return;
        }

        if (!dropoffDateOnly.value) {
            alert('Lütfen teslim tarihini seçin.');
            return;
        }

        if (new Date(d) <= new Date(p)) {
            alert('Teslim tarihi alış tarihinden sonra olmalıdır.');
            return;
        }

        calcPrice();
        goPanel(2);
    }

    document.querySelectorAll('.time-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            const target = this.dataset.target;
            const time = this.dataset.time;

            document.querySelectorAll(`.time-btn[data-target="${target}"]`).forEach(b => b.classList.remove('active'));
            this.classList.add('active');

            if (target === 'pickup') {
                pickupTime = time;
            } else {
                dropoffTime = time;
            }

            syncHiddenDates();
            calcPrice();
        });
    });

    pickupDateOnly.addEventListener('change', function () {
        syncDropoffMin();
        syncHiddenDates();
        calcPrice();
    });

    dropoffDateOnly.addEventListener('change', function () {
        syncHiddenDates();
        calcPrice();
    });

    syncDropoffMin();
    syncHiddenDates();
    calcPrice();
</script>

</body>
</html>