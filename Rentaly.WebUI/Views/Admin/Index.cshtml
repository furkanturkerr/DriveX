@model dynamic

@{
    Layout = null;
}

<style>
  .sb-nav a,
  .sb-nav a:hover,
  .sb-nav a:visited,
  .sb-nav a:active {
    text-decoration: none;
    color: inherit;
  }

  .ni {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 18px;
    cursor: pointer;
    color: #8b949e;
    border-left: 2px solid transparent;
    transition: all .12s;
    text-decoration: none;
  }

  .ni:hover {
    background: #161b22;
    color: #c9d1d9;
    text-decoration: none;
  }

  .ni.act {
    background: #161b22;
    color: #22c55e;
    border-left-color: #22c55e;
    text-decoration: none;
  }

  .sni {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 18px 7px 44px;
    cursor: pointer;
    color: #8b949e;
    font-size: 12px;
    text-decoration: none;
  }

  .sb-subsec {
    font-size: 11px;
    color: #6e7681;
    margin: 10px 0 6px 12px;
    text-transform: uppercase;
    letter-spacing: .5px;
  }
  
  .sni:hover {
    color: #c9d1d9;
    background: #161b22;
    text-decoration: none;
  }

  .sni.act {
    color: #22c55e;
    text-decoration: none;
  }

  .sni::before {
    content: '';
    width: 4px;
    height: 4px;
    background: currentColor;
    border-radius: 50%;
    margin-right: 4px;
    flex-shrink: 0;
  }
</style>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

@await Component.InvokeAsync("_AdminStyleComponentPartial")

<div class="adm">
  @await Component.InvokeAsync("_AdminSidebarComponentPartial")


<div class="main">
  @await Component.InvokeAsync("_AdminHeaderComponentPartial")


  <div class="pg">
    @RenderBody()
  </div>
</div>
</div>

<script>
const pmap={db:'Dashboard',hero:'Ana Sayfa — Hero',about:'Hakkımızda',srv:'Servisler',bnr:'Kampanya Banneri',yor:'Yorumlar',cars:'Araç Yönetimi',mdl:'Kategoriler',res:'Rezervasyonlar',msg:'Mesajlar',usr:'Kullanıcılar',set:'Ayarlar'};
function go(id,el){
  document.querySelectorAll('.pg-sec').forEach(p=>p.classList.remove('on'));
  const p=document.getElementById('pg-'+id);
  if(p)p.classList.add('on');
  document.getElementById('ptitle').textContent=pmap[id]||id;
  document.querySelectorAll('.ni,.sni').forEach(n=>n.classList.remove('act'));
  if(el){el.classList.add('act');const sn=el.closest('.sn');if(sn){sn.classList.add('op');const pid=sn.id.replace('sn-','');const ch=document.getElementById('c-'+sn.id);if(ch)ch.classList.add('op');}}
}
function tog(id, el) {
  const sn = document.getElementById(id);
  const ch = document.getElementById('c-' + id);
  sn.classList.toggle('op');
  if (ch) ch.classList.toggle('op');
}
</script>
