@model List<Rentaly.DtoLayer.FaqDtos.ResultFaqDto>

@{
    var leftFaqs = Model.Take((Model.Count + 1) / 2).ToList();
    var rightFaqs = Model.Skip((Model.Count + 1) / 2).ToList();
}

<section id="section-faq">
    <div class="container">
        <div class="row">
            <div class="col text-center">
                <h2>Sıkça Sorulan Sorular</h2>
                <div class="spacer-20"></div>
            </div>
        </div>

        <div class="row g-custom-x">
            <div class="col-md-6 wow fadeInUp">
                <div class="accordion secondary">
                    <div class="accordion-section">
                        @for (int i = 0; i < leftFaqs.Count; i++)
                        {
                            var item = leftFaqs[i];
                            var tabId = $"accordion-left-{i}";

                            <div class="accordion-section-title" data-tab="#@tabId">
                                @item.Question
                            </div>
                            <div class="accordion-section-content" id="@tabId">
                                <p>@item.Answer</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6 wow fadeInUp">
                <div class="accordion secondary">
                    <div class="accordion-section">
                        @for (int i = 0; i < rightFaqs.Count; i++)
                        {
                            var item = rightFaqs[i];
                            var tabId = $"accordion-right-{i}";

                            <div class="accordion-section-title" data-tab="#@tabId">
                                @item.Question
                            </div>
                            <div class="accordion-section-content" id="@tabId">
                                <p>@item.Answer</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>