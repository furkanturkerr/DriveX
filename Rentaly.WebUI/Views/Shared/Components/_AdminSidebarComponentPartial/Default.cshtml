<div class="sb">
  <div class="sb-logo">
    <div class="sb-logo-mark">
      <svg viewBox="0 0 24 18" fill="none">
        <path d="M3 9l2.5-5h13l2.5 5" stroke="#fff" stroke-width="1.8" stroke-linecap="round"/>
        <path d="M3 9h18" stroke="#fff" stroke-width="1.8"/>
        <path d="M1 9l-0.5 3.5V14h1.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M23 9l0.5 3.5V14h-1.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="6.5" cy="14" r="2" stroke="#fff" stroke-width="1.5"/>
        <circle cx="17.5" cy="14" r="2" stroke="#fff" stroke-width="1.5"/>
      </svg>
    </div>
    <div>
      <div class="sb-brand">rent<span>aly</span></div>
      <div class="sb-tag">Admin Panel v2.0</div>
    </div>
  </div>

  <div class="sb-nav">

    <a class="ni" asp-controller="Dashboard" asp-action="Index">
      <svg viewBox="0 0 16 16" fill="currentColor"><path d="M2 2h5v5H2zm7 0h5v5H9zm-7 7h5v5H2zm7 0h5v5H9z" opacity=".85"/></svg>
      Dashboard
    </a>

    <a class="ni" asp-controller="Default" asp-action="Index" target="_blank">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
        <path d="M6 3H3a1 1 0 0 0-1 1v9a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1v-3"/>
        <path d="M10 2h4v4M14 2l-6 6"/>
      </svg>
      Siteye Git
    </a>

    @* ── SİTE İÇERİĞİ ── *@
    <div class="sb-sec">Site İçeriği</div>

    <div class="ni" onclick="tog('sn-say',this)">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
        <rect x="2" y="2" width="12" height="12" rx="2"/>
        <path d="M5 6h6M5 9h4"/>
      </svg>
      Sayfalar
      <svg class="chv" id="c-sn-say" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 3l3 3-3 3"/>
      </svg>
    </div>
    <div class="sn" id="sn-say">
      <a class="sni" asp-controller="About"       asp-action="AboutList">Hakkımızda</a>
      <a class="sni" asp-controller="Service"     asp-action="ServiceList">Servisler</a>
      <a class="sni" asp-controller="Banner"      asp-action="BannerList">Banner</a>
      <a class="sni" asp-controller="Testimonial" asp-action="TestimonialList">Yorumlar</a>
      <a class="sni" asp-controller="Faq"         asp-action="FaqList">SSS</a>
      <a class="sni" asp-controller="Contact"     asp-action="ContactList">İletişim</a>
      <a class="sni" asp-controller="Footer"      asp-action="FooterList">Footer</a>
    </div>

    @* ── BLOG ── *@
    <div class="sb-sec">Blog</div>

    <a class="ni" asp-controller="Blog" asp-action="BlogList">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
        <rect x="2" y="2" width="12" height="12" rx="2"/>
        <path d="M5 5h6M5 8h6M5 11h4"/>
      </svg>
      Yazılar
    </a>

    <a class="ni" asp-controller="BlogCategory" asp-action="BlogCategoryList">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
        <path d="M2 3h5l1 2h6v8H2z"/>
      </svg>
      Blog Kategorileri
    </a>

    @* ── ARAÇ YÖNETİMİ ── *@
    <div class="sb-sec">Araç Yönetimi</div>

    <a class="ni" asp-controller="Car" asp-action="CarList">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
        <path d="M2 8l2-4h8l2 4"/><path d="M2 8h12"/>
        <path d="M1 8v3h1.5m10 0H14V8"/>
        <circle cx="5" cy="11" r="1.5"/><circle cx="11" cy="11" r="1.5"/>
      </svg>
      Araçlar
      <span class="bx">24</span>
    </a>

    <div class="ni" onclick="tog('sn-arac',this)">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
        <path d="M2 4h12M2 8h8M2 12h5"/>
      </svg>
      Tanımlamalar
      <svg class="chv" id="c-sn-arac" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 3l3 3-3 3"/>
      </svg>
    </div>
    <div class="sn" id="sn-arac">
      <a class="sni" asp-controller="Brand"       asp-action="BrandList">Markalar</a>
      <a class="sni" asp-controller="CarModel"    asp-action="CarModelList">Modeller</a>
      <a class="sni" asp-controller="CarCategory" asp-action="CarCategoryList">Kategoriler</a>
      <a class="sni" asp-controller="Branch"      asp-action="BranchList">Şubeler</a>
    </div>

    @* ── İŞLEMLER ── *@
    <div class="sb-sec">İşlemler</div>

    <a class="ni" asp-controller="Reservation" asp-action="ReservationList">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
        <rect x="2" y="3" width="12" height="11" rx="1.5"/>
        <path d="M5 1v4M11 1v4M2 7h12"/>
      </svg>
      Rezervasyonlar
      <span class="bx bw">8</span>
    </a>

    <a class="ni" asp-controller="Message" asp-action="MessageList">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
        <path d="M2 3h12v9H2z"/><path d="M2 3l6 5 6-5"/>
      </svg>
      Mesajlar
      <span class="bx br">3</span>
    </a>

    <a class="ni" asp-controller="User" asp-action="UserList">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
        <circle cx="8" cy="5.5" r="2.5"/>
        <path d="M3 14a5 5 0 0 1 10 0"/>
      </svg>
      Kullanıcılar
    </a>

    @* ── SİSTEM ── *@
    <div class="sb-sec">Sistem</div>

    <a class="ni" asp-controller="Settings" asp-action="Index">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
        <circle cx="8" cy="8" r="2.5"/>
        <path d="M8 2v1M8 13v1M2 8h1M13 8h1M3.5 3.5l.7.7M11.8 11.8l.7.7M3.5 12.5l.7-.7M11.8 4.2l.7-.7"/>
      </svg>
      Ayarlar
    </a>

  </div>

  <div class="sb-footer">
    <div class="av">AD</div>
    <div>
      <div class="av-name">Admin</div>
      <div class="av-role">Süper Admin</div>
    </div>
    <svg style="margin-left:auto;width:14px;height:14px;color:#6e7681"
         viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
      <path d="M10 3l5 5-5 5M15 8H6M1 3v10"/>
    </svg>
  </div>
</div>